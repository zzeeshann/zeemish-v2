---
export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryChips from '../../components/CategoryChips.astro';
import { formatTime } from '../../lib/format';
import { deriveSlug, pieceUrl } from '../../lib/slug';
import {
  getCategories,
  getCategoryBySlug,
  getPieceIdsInCategory,
} from '../../lib/categories';

const db = Astro.locals.runtime.env.DB;
const slug = Astro.params.slug ?? '';

// Validate the slug shape before hitting D1 — same kebab-case rule
// the Categoriser enforces via `normaliseSlug`. Malformed slugs 404
// fast without a query.
if (!/^[a-z0-9][a-z0-9-]{0,58}[a-z0-9]$/.test(slug)) {
  return new Response('Not found', { status: 404 });
}

const category = await getCategoryBySlug(db, slug);
if (!category) {
  return new Response('Not found', { status: 404 });
}

// Category chip bar — same list as the unfiltered view, with this
// slug rendered as the active chip.
const categories = await getCategories(db);
const pieceIds = await getPieceIdsInCategory(db, slug);

const dailyPieces = await getCollection('dailyPieces');
const pieces = [...dailyPieces].filter((p) => pieceIds.has(p.data.pieceId));
// publishedAt DESC tiebreaker — same ordering as the unfiltered list.
pieces.sort((a, b) => {
  if (a.data.date !== b.data.date) return b.data.date.localeCompare(a.data.date);
  return b.data.publishedAt - a.data.publishedAt;
});

// Count shown on the "All pieces" chip — total across the library,
// not this category — so the chip bar surface stays consistent
// across both views.
const totalPieces = dailyPieces.length;

// Group by month for display. Same logic as library/index.astro.
type Piece = typeof pieces[number];
const months: { label: string; pieces: Piece[] }[] = [];
const monthNames = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];
for (const piece of pieces) {
  const [year, monthStr] = piece.data.date.split('-');
  const label = `${monthNames[parseInt(monthStr, 10) - 1]} ${year}`;
  const last = months[months.length - 1];
  if (last && last.label === label) {
    last.pieces.push(piece);
  } else {
    months.push({ label, pieces: [piece] });
  }
}

const title = `${category.name} — Library — Zeemish`;
const metaDescription = category.description ?? `Every Zeemish piece in the ${category.name} category.`;
---

<BaseLayout title={title} description={metaDescription}>
  <div class="pt-6 pb-10">
    <nav class="text-sm text-zee-muted mb-4">
      <a href="/library/" class="hover:text-zee-primary">Library</a>
      <span class="mx-2 opacity-40" aria-hidden="true">·</span>
      <span class="text-zee-text">{category.name}</span>
    </nav>
    <h1 class="text-3xl md:text-4xl font-bold mb-3 leading-tight tracking-tight">{category.name}</h1>
    {category.description && (
      <p class="text-lg text-zee-muted mb-6">{category.description}</p>
    )}
    <p class="text-sm text-zee-muted">
      <span class="text-zee-text font-medium">{pieces.length}</span> {pieces.length === 1 ? 'piece' : 'pieces'} in this category
    </p>
  </div>

  <CategoryChips categories={categories} activeSlug={category.slug} totalPieces={totalPieces} />

  {pieces.length === 0 ? (
    <div class="py-12 border-t border-zee-border/60">
      <p class="text-zee-muted italic">
        No pieces in this category yet. <a href="/library/" class="underline hover:text-zee-primary">Back to the full library.</a>
      </p>
    </div>
  ) : (
    <>
      {pieces.length > 2 && (
        <div class="mb-8 border-b border-zee-border/60 py-3">
          <label class="sr-only" for="library-filter">Filter pieces</label>
          <input
            id="library-filter"
            type="search"
            placeholder="Filter within this category…"
            class="w-full bg-transparent border-0 text-sm placeholder:text-zee-muted focus:outline-none focus:ring-2 focus:ring-zee-primary/30 rounded px-1 -mx-1"
            data-library-filter
          />
        </div>
      )}

      <div class="space-y-12 pb-12" data-library-list>
        {months.map((month) => (
          <section data-month-group>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">
              {month.label}
            </h2>
            <ul class="divide-y divide-zee-border/60">
              {month.pieces.map((piece) => (
                <li data-library-item>
                  <a
                    href={pieceUrl(piece.data.date, deriveSlug(piece.id))}
                    class="block py-5 group relative pl-4 -ml-4 border-l-2 border-transparent hover:border-zee-primary transition-all"
                  >
                    <div class="flex items-baseline gap-3 mb-1">
                      <span class="text-xs text-zee-muted tabular-nums">
                        {piece.data.date.slice(-2)} {monthNames[parseInt(piece.data.date.split('-')[1], 10) - 1].slice(0, 3)}
                      </span>
                      <span class="text-zee-muted/40" aria-hidden="true">·</span>
                      <span class="text-xs text-zee-muted">{formatTime(piece.data.estimatedTime)}</span>
                    </div>
                    <h3 class="text-lg md:text-xl font-semibold leading-snug group-hover:text-zee-primary transition-colors" data-title>
                      {piece.data.title}
                    </h3>
                    <p class="text-sm text-zee-muted mt-2 leading-relaxed">{piece.data.description}</p>
                    {piece.data.underlyingSubject && (
                      <span
                        class="inline-block mt-3 text-[11px] font-medium uppercase tracking-wider text-zee-gold"
                        data-subject
                      >
                        {piece.data.underlyingSubject}
                      </span>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>

      <p class="text-sm text-zee-muted hidden pb-12" data-empty-match>
        No pieces match that filter within this category.
      </p>
    </>
  )}
</BaseLayout>

<script>
  const filter = document.querySelector<HTMLInputElement>('[data-library-filter]');
  const items = Array.from(document.querySelectorAll<HTMLElement>('[data-library-item]'));
  const groups = Array.from(document.querySelectorAll<HTMLElement>('[data-month-group]'));
  const emptyNote = document.querySelector<HTMLElement>('[data-empty-match]');

  if (filter) {
    filter.addEventListener('input', () => {
      const q = filter.value.trim().toLowerCase();
      let anyVisible = false;

      for (const item of items) {
        const title = item.querySelector<HTMLElement>('[data-title]')?.textContent ?? '';
        const subject = item.querySelector<HTMLElement>('[data-subject]')?.textContent ?? '';
        const match = !q || title.toLowerCase().includes(q) || subject.toLowerCase().includes(q);
        item.style.display = match ? '' : 'none';
        if (match) anyVisible = true;
      }

      for (const group of groups) {
        const visible = Array.from(group.querySelectorAll<HTMLElement>('[data-library-item]'))
          .some((el) => el.style.display !== 'none');
        group.style.display = visible ? '' : 'none';
      }

      if (emptyNote) emptyNote.style.display = anyVisible ? 'none' : 'block';
    });
  }
</script>
