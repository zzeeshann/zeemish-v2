---
import { getCollection, render } from 'astro:content';
import LessonLayout from '../../../layouts/LessonLayout.astro';
import MadeBy from '../../../components/MadeBy.astro';
import { deriveSlug } from '../../../lib/slug';
import '../../../styles/made.css';

export async function getStaticPaths() {
  const pieces = await getCollection('dailyPieces');
  // Cross-collection self-join — for each daily piece, find the
  // interactive whose sourcePieceId matches (Area 4 sub-task 4.6).
  // The content collection is the source of truth (per 4.2); no D1
  // lookup or runtime fetch needed. The prior `qualityFlag !== 'low'`
  // filter was dropped 2026-04-24 when Generator switched from
  // abandon-on-max-fail to ship-as-low — flagged-low interactives are
  // still useful to readers (same posture as flagged-low daily pieces)
  // and surface via the last-beat prompt alongside clean passes.
  const interactives = await getCollection('interactives');
  const interactiveByPiece = new Map<string, (typeof interactives)[number]>();
  for (const i of interactives) {
    if (i.data.sourcePieceId) {
      interactiveByPiece.set(i.data.sourcePieceId, i);
    }
  }
  return pieces.map((piece) => {
    const interactive = interactiveByPiece.get(piece.data.pieceId) ?? null;
    return {
      params: { date: piece.data.date, slug: deriveSlug(piece.id) },
      props: { piece, interactive },
    };
  });
}

const { piece, interactive } = Astro.props;
const { Content } = await render(piece);

const interactivePayload = interactive
  ? {
      slug: interactive.data.slug,
      title: interactive.data.title,
      questionCount:
        interactive.data.content.type === 'quiz'
          ? interactive.data.content.questions.length
          : null,
    }
  : null;
---

<LessonLayout
  title={piece.data.title}
  estimatedTime={piece.data.estimatedTime}
  audioBeats={piece.data.audioBeats}
  beatCount={piece.data.beatCount}
  subject={piece.data.underlyingSubject}
  date={piece.data.date}
  pieceId={piece.data.pieceId}
  voiceScore={piece.data.voiceScore}
  qualityFlag={piece.data.qualityFlag}
  description={piece.data.description}
  interactive={interactivePayload}
>
  <Content />
  <MadeBy date={piece.data.date} pieceId={piece.data.pieceId} />
</LessonLayout>

<script>
  import '../../../interactive/register';
</script>
