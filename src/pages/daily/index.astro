---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatTime, formatDate } from '../../lib/format';
import { deriveSlug, pieceUrl } from '../../lib/slug';

const pieces = await getCollection('dailyPieces');
// Every published piece shows here. Tier surfacing happens on the piece
// page. See docs/DECISIONS.md 2026-04-17 "Soften quality surfacing".
// publishedAt DESC tiebreaker for multi-per-day cadence.
const sorted = [...pieces].sort((a, b) => {
  if (a.data.date !== b.data.date) return b.data.date.localeCompare(a.data.date);
  return b.data.publishedAt - a.data.publishedAt;
});
---

<BaseLayout title="Daily — Zeemish" description="Today's news, explained.">
  <h1 class="text-3xl md:text-4xl font-bold mb-3 leading-tight">Daily Pieces</h1>
  <p class="text-lg text-zee-muted mb-10">Today's news, explained. One piece, every morning.</p>

  {sorted.length === 0 ? (
    <p class="text-zee-muted italic">No daily pieces yet. The first one is coming soon.</p>
  ) : (
    <div class="space-y-4">
      {sorted.map((piece) => (
        <a
          href={pieceUrl(piece.data.date, deriveSlug(piece.id))}
          class="block p-5 rounded-xl border border-zee-border hover:border-zee-primary/30 hover:shadow-sm transition-all group"
        >
          <div class="flex items-baseline justify-between mb-1">
            <span class="text-xs text-zee-muted">{formatDate(piece.data.date)}</span>
            <span class="text-xs text-zee-muted">{formatTime(piece.data.estimatedTime)}</span>
          </div>
          <h2 class="text-lg font-bold group-hover:text-zee-primary transition-colors">
            {piece.data.title}
          </h2>
          <p class="text-sm text-zee-muted mt-1">{piece.data.description}</p>
          {piece.data.newsSource && (
            <span class="text-xs text-zee-muted mt-2 inline-block">Source: {piece.data.newsSource}</span>
          )}
        </a>
      ))}
    </div>
  )}
</BaseLayout>
