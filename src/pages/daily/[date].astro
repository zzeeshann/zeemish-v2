---
import { getCollection, render } from 'astro:content';
import LessonLayout from '../../layouts/LessonLayout.astro';

export async function getStaticPaths() {
  const pieces = await getCollection('dailyPieces');
  return pieces.map((piece) => ({
    params: { date: piece.data.date },
    props: { piece },
  }));
}

const { piece } = Astro.props;
const { Content } = await render(piece);
const isLowQuality = piece.data.qualityFlag === 'low';
---

<LessonLayout
  title={piece.data.title}
  estimatedTime={piece.data.estimatedTime}
  audioSrc={piece.data.audioSrc}
  beatCount={piece.data.beatCount}
  subject={piece.data.underlyingSubject}
  date={piece.data.date}
>
  {isLowQuality && (
    <div class="mb-6 p-4 rounded-lg border border-yellow-500/30 bg-yellow-50 text-sm">
      <p class="font-medium text-yellow-900">A note on today's piece.</p>
      <p class="text-yellow-800 mt-1">
        This one didn't fully pass our voice, structure, and fact checks.
        We published it anyway so the day isn't blank — but we're leaving it
        out of the library archive. Feedback welcome at <a href="mailto:hello@zeemish.io" class="underline">hello@zeemish.io</a>.
      </p>
    </div>
  )}
  <Content />
</LessonLayout>

<script>
  import '../../interactive/register';
</script>
