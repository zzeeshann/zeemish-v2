---
import { getCollection, render } from 'astro:content';
import LessonLayout from '../../../layouts/LessonLayout.astro';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  const courses = await getCollection('courses');

  return lessons.map((lesson) => {
    const course = courses.find((c) => c.data.slug === lesson.data.course);
    return {
      params: {
        course: lesson.data.course,
        lesson: lesson.data.lessonNumber.toString(),
      },
      props: {
        lesson,
        courseTitle: course?.data.title ?? lesson.data.course,
      },
    };
  });
}

const { lesson, courseTitle } = Astro.props;
const { Content } = await render(lesson);
---

<LessonLayout
  title={lesson.data.title}
  courseTitle={courseTitle}
  courseSlug={lesson.data.course}
  lessonNumber={lesson.data.lessonNumber}
  estimatedTime={lesson.data.estimatedTime}
  audioSrc={lesson.data.audioSrc}
>
  <Content />
</LessonLayout>

<script>
  import '../../../interactive/register';
</script>
