---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const courses = await getCollection('courses');
---

<BaseLayout title="Courses — Zeemish" description="Browse all Zeemish courses.">
  <h1 class="text-3xl md:text-4xl font-bold mb-3 leading-tight">Courses</h1>
  <p class="text-lg text-zee-muted mb-10">Learn things that matter.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {courses.map((course) => (
      <a
        href={`/courses/${course.data.slug}/`}
        class="block p-6 rounded-xl border border-zee-border hover:border-zee-primary/30 hover:shadow-sm transition-all group"
      >
        <h2 class="text-xl font-bold mb-2 group-hover:text-zee-primary transition-colors">
          {course.data.title}
        </h2>
        <p class="text-zee-muted mb-4">{course.data.description}</p>
        <p class="text-sm text-zee-muted">
          {course.data.lessonCount} lessons &middot; {course.data.estimatedTotalTime}
        </p>
      </a>
    ))}
  </div>
</BaseLayout>
