---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getUser } from '../lib/db';
import { formatDate } from '../lib/format';

const db = Astro.locals.runtime.env.DB;
const userId = Astro.locals.userId;
const user = await getUser(db, userId);

const hasEmail = !!user?.email;

// Member-since date (eyebrow). User.created_at is epoch ms.
let memberSince = '';
if (user?.created_at) {
  const iso = new Date(user.created_at).toISOString().slice(0, 10);
  memberSince = formatDate(iso);
}

// Progress stats for signed-in users. Two counters, same shape as the
// dashboard Library stats strip.
let completedCount = 0;
let inProgressCount = 0;
if (hasEmail) {
  try {
    const completed = await db
      .prepare('SELECT COUNT(*) as n FROM progress WHERE user_id = ? AND completed_at IS NOT NULL')
      .bind(userId)
      .first<{ n: number }>();
    completedCount = completed?.n ?? 0;

    const inProgress = await db
      .prepare('SELECT COUNT(*) as n FROM progress WHERE user_id = ? AND completed_at IS NULL AND current_beat IS NOT NULL')
      .bind(userId)
      .first<{ n: number }>();
    inProgressCount = inProgress?.n ?? 0;
  } catch { /* table may not exist in dev; leave zeros */ }
}
---

<BaseLayout title="Your account — Zeemish">

  <div class="pt-6 pb-10">
    {hasEmail && memberSince && (
      <p class="text-xs font-semibold uppercase tracking-widest text-zee-gold mb-2">
        Member since {memberSince}
      </p>
    )}
    <h1 class="text-3xl md:text-4xl font-bold mb-3 leading-tight tracking-tight">Your account</h1>
    <p class="text-lg text-zee-muted">
      {hasEmail
        ? 'Your reading progress syncs across devices while you\'re signed in.'
        : 'You\'re browsing anonymously. Add an email to save progress across devices.'}
    </p>
  </div>

  {hasEmail && (
    <section class="mb-10">
      <h2 class="text-sm font-medium text-zee-muted uppercase tracking-wide mb-4">Your reading</h2>
      <div class="grid grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-zee-border text-center">
          <div class="text-2xl font-bold text-zee-primary">{completedCount}</div>
          <div class="text-sm text-zee-muted">{completedCount === 1 ? 'Piece' : 'Pieces'} completed</div>
        </div>
        <div class="p-4 rounded-xl border border-zee-border text-center">
          <div class="text-2xl font-bold text-zee-primary">{inProgressCount}</div>
          <div class="text-sm text-zee-muted">In progress</div>
        </div>
      </div>
    </section>
  )}

  <section class="mb-10">
    <h2 class="text-sm font-medium text-zee-muted uppercase tracking-wide mb-4">Identity</h2>
    {hasEmail ? (
      <p class="text-zee-text">
        Signed in as <strong>{user!.email}</strong>
      </p>
    ) : (
      <a
        href="/login/?upgrade=1"
        class="inline-flex items-center gap-2 px-4 py-2 bg-zee-primary text-white rounded-lg text-sm font-medium hover:opacity-90 transition-opacity"
      >
        Add email
      </a>
    )}
  </section>

  <section class="mb-10">
    <h2 class="text-sm font-medium text-zee-muted uppercase tracking-wide mb-4">Actions</h2>
    <div class="flex flex-wrap gap-3">
      <a href="/library/" class="text-sm text-zee-primary hover:underline">
        Browse library →
      </a>
      {hasEmail && (
        <button
          id="logout-btn"
          class="text-sm text-zee-muted hover:text-zee-text transition-colors"
        >
          Log out
        </button>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const logoutBtn = document.getElementById('logout-btn');
  logoutBtn?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/';
  });
</script>
