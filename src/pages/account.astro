---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getUser } from '../lib/db';

const db = Astro.locals.runtime.env.DB;
const userId = Astro.locals.userId;
const user = await getUser(db, userId);

const hasEmail = !!user?.email;
---

<BaseLayout title="Your account — Zeemish">
  <h1 class="text-2xl md:text-3xl font-bold mb-8">Your account</h1>

  <!-- Identity -->
  <section class="mb-10">
    <h2 class="text-sm font-medium text-zee-muted uppercase tracking-wide mb-4">Identity</h2>
    {hasEmail ? (
      <p class="text-zee-text">
        Signed in as <strong>{user!.email}</strong>
      </p>
    ) : (
      <div>
        <p class="text-zee-muted mb-4">
          You're browsing anonymously. Add an email to save your progress across devices.
        </p>
        <a
          href="/login/?upgrade=1"
          class="inline-flex items-center gap-2 px-4 py-2 bg-zee-primary text-white rounded-lg text-sm font-medium hover:opacity-90 transition-opacity"
        >
          Add email
        </a>
      </div>
    )}
  </section>

  <!-- Actions -->
  <section>
    <h2 class="text-sm font-medium text-zee-muted uppercase tracking-wide mb-4">Actions</h2>
    <div class="flex flex-wrap gap-3">
      <a href="/library/" class="px-4 py-2 text-sm font-medium rounded-lg border border-zee-border hover:bg-zee-border/50 transition-colors">
        Browse library
      </a>
      {hasEmail && (
        <button
          id="logout-btn"
          class="px-4 py-2 text-sm font-medium rounded-lg border border-zee-border hover:bg-zee-border/50 transition-colors"
        >
          Log out
        </button>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const logoutBtn = document.getElementById('logout-btn');
  logoutBtn?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/';
  });
</script>
