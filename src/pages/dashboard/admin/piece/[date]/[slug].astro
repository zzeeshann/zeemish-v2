---
export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import { getUser } from '../../../../../lib/db';
import { auditTier, auditTierLabel } from '../../../../../lib/audit-tier';
import { pipelineStepLabel } from '../../../../../lib/pipeline-steps';
import { deriveSlug, pieceUrl } from '../../../../../lib/slug';

const db = Astro.locals.runtime.env.DB;
const userId = Astro.locals.userId;
const user = userId ? await getUser(db, userId) : null;
const ADMIN_EMAIL = (Astro.locals.runtime.env as Record<string, string>).ADMIN_EMAIL;

if (!user?.email || user.email !== ADMIN_EMAIL) {
  return Astro.redirect(`/login/?redirect=/dashboard/admin/`);
}

const date = String(Astro.params.date ?? '').trim();
const slug = String(Astro.params.slug ?? '').trim();
if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) {
  return new Response('Invalid date', { status: 400 });
}
if (!/^[a-z0-9][a-z0-9-]*$/.test(slug)) {
  return new Response('Invalid slug', { status: 400 });
}

// --- Fetch every per-day data source the operator might want -----------

type Piece = {
  date: string;
  headline: string;
  underlying_subject: string | null;
  source_story: string | null;
  voice_score: number | null;
  fact_check_passed: number | null;
  quality_flag: 'low' | null;
  word_count: number | null;
  beat_count: number | null;
  reading_minutes: number | null;
  has_audio: number | null;
  interactive_id: string | null;
  published_at: number | null;
  created_at: number;
};

type AuditRow = {
  auditor: string;
  passed: number;
  score: number | null;
  notes: string | null;
  draft_id: string;
  created_at: number;
};

type PipelineRow = {
  step: string;
  status: string;
  data: string | null;
  created_at: number;
};

type CandidateRow = {
  id: string;
  headline: string;
  source: string;
  category: string | null;
  summary: string | null;
  url: string | null;
  teachability_score: number | null;
  selected: number | null;
  created_at: number;
};

type ObserverRow = {
  id: string;
  severity: 'info' | 'warn' | 'escalation';
  title: string;
  body: string;
  context: string | null;
  acknowledged_at: number | null;
  created_at: number;
};

type AudioRow = {
  beat_name: string;
  r2_key: string;
  public_url: string;
  character_count: number;
  duration_seconds: number | null;
  request_id: string | null;
  model: string;
  voice_id: string;
  generated_at: number;
};

type ZitaMessage = {
  user_id: string;
  role: 'user' | 'assistant';
  content: string;
  created_at: number;
};

let piece: Piece | null = null;
let audits: AuditRow[] = [];
let pipeline: PipelineRow[] = [];
let candidates: CandidateRow[] = [];
let observerEvents: ObserverRow[] = [];
let audioRows: AudioRow[] = [];
let zitaMessages: ZitaMessage[] = [];

// Resolve piece_id from (date, slug) via the content collection. The
// filename convention is `YYYY-MM-DD-{slug}.mdx`, so deriveSlug(entry.id)
// matches the URL slug. All piece-scoped queries below bind on
// piece_id — including the three day-keyed tables (audit_results,
// pipeline_log, daily_candidates) which gained a piece_id column in
// migration 0018 and were backfilled for historical rows in 0019.
// observer_events stays on a 36h day window (legitimate day view of
// operator events). See DECISIONS 2026-04-22 "piece_id columns on
// day-keyed tables".
const collectionEntries = await getCollection('dailyPieces');
const entry = collectionEntries.find(
  (p) => p.data.date === date && deriveSlug(p.id) === slug,
);
const pieceId: string | null = entry?.data.pieceId ?? null;

try {
  if (pieceId) {
    piece = await db
      .prepare('SELECT * FROM daily_pieces WHERE id = ? LIMIT 1')
      .bind(pieceId)
      .first<Piece>();
  } else {
    // Fall back to the date-keyed lookup when the collection entry is
    // missing (rare — pre-Phase-7 MDX without pieceId, or a slug typo).
    // At multi-per-day this picks an arbitrary same-date piece; the
    // admin sees a 404-ish "No piece" display if that piece also doesn't
    // resolve.
    piece = await db
      .prepare('SELECT * FROM daily_pieces WHERE date = ? ORDER BY published_at DESC LIMIT 1')
      .bind(date)
      .first<Piece>();
  }

  // Piece-scoped queries. All three tables have piece_id populated
  // (migration 0018 + 0019 backfill). If pieceId is somehow null
  // (MDX without pieceId frontmatter — shouldn't happen post-Phase-7),
  // we fall back to date-keyed queries that will show "the day's
  // activity" — imperfect at multi-per-day but better than an empty
  // page.
  if (pieceId) {
    const auditsRes = await db
      .prepare('SELECT auditor, passed, score, notes, draft_id, created_at FROM audit_results WHERE piece_id = ? ORDER BY created_at ASC')
      .bind(pieceId)
      .all<AuditRow>();
    audits = auditsRes.results;

    const pipelineRes = await db
      .prepare('SELECT step, status, data, created_at FROM pipeline_log WHERE piece_id = ? ORDER BY created_at ASC')
      .bind(pieceId)
      .all<PipelineRow>();
    pipeline = pipelineRes.results;

    const candsRes = await db
      .prepare('SELECT id, headline, source, category, summary, url, teachability_score, selected, created_at FROM daily_candidates WHERE piece_id = ? ORDER BY teachability_score DESC')
      .bind(pieceId)
      .all<CandidateRow>();
    candidates = candsRes.results;
  } else {
    const auditsRes = await db
      .prepare('SELECT auditor, passed, score, notes, draft_id, created_at FROM audit_results WHERE task_id = ? ORDER BY created_at ASC')
      .bind(`daily/${date}`)
      .all<AuditRow>();
    audits = auditsRes.results;

    const pipelineRes = await db
      .prepare('SELECT step, status, data, created_at FROM pipeline_log WHERE run_id = ? ORDER BY created_at ASC')
      .bind(date)
      .all<PipelineRow>();
    pipeline = pipelineRes.results;

    const candsRes = await db
      .prepare('SELECT id, headline, source, category, summary, url, teachability_score, selected, created_at FROM daily_candidates WHERE date = ? ORDER BY teachability_score DESC')
      .bind(date)
      .all<CandidateRow>();
    candidates = candsRes.results;
  }

  // observer_events — strict piece_id scoping (Area 3 sub-task 3.2,
  // 2026-04-24). Previously fell back to a 36h day window for legacy
  // null-piece_id rows, which pooled both same-day pieces' events plus
  // system events (admin_settings_changed, zita_rate_limited) onto
  // each piece page. With site-worker Zita writers now threading
  // piece_id (sub-task 3.2), the fallback was protecting only pre-0020
  // historical rows — those stay visible on the global admin feed, not
  // here. System events that aren't about a piece correctly never
  // surface on a piece page.
  if (pieceId) {
    const obsRes = await db
      .prepare('SELECT * FROM observer_events WHERE piece_id = ? ORDER BY created_at ASC')
      .bind(pieceId)
      .all<ObserverRow>();
    observerEvents = obsRes.results;
  }
  // Null pieceId path is reachable via slug typo (`/piece/<date>/<wrong-slug>/`)
  // — content-collection .find() returns undefined. In that case piece /
  // audits / pipeline / candidates queries fall back to date-keyed lookup
  // (lenient) while audio / zita / observer return empty (strict). That
  // inconsistency is pre-existing, not a 3.2 regression; FOLLOWUPS has
  // `[open] 2026-04-24: Coherent null-pieceId handling` to unify later.

  // Audio scoped by piece_id (migration 0015 rebuilt the PK there).
  if (pieceId) {
    const audioRes = await db
      .prepare(
        `SELECT beat_name, r2_key, public_url, character_count, duration_seconds,
                request_id, model, voice_id, generated_at
         FROM daily_piece_audio WHERE piece_id = ? ORDER BY generated_at ASC`,
      )
      .bind(pieceId)
      .all<AudioRow>();
    audioRows = audioRes.results;
  }
} catch { /* leave empty */ }

// Zita query is in its own try so a failure in the audio section
// above doesn't silently remove the "Questions from readers" block.
// Scoped by piece_id (migration 0013 + 0014 backfill ensured every
// row has it populated). Pre-backfill null-piece_id rows exist only
// in snapshot tables, not in zita_messages.
if (pieceId) {
  try {
    const zitaRes = await db
      .prepare(
        `SELECT user_id, role, content, created_at
         FROM zita_messages WHERE piece_id = ? ORDER BY created_at ASC`,
      )
      .bind(pieceId)
      .all<ZitaMessage>();
    zitaMessages = zitaRes.results;
  } catch { /* leave empty */ }
}

type ZitaConversation = { user_id: string; msgs: ZitaMessage[] };
const zitaConvos: ZitaConversation[] = (() => {
  const byUser = new Map<string, ZitaMessage[]>();
  for (const m of zitaMessages) {
    if (!byUser.has(m.user_id)) byUser.set(m.user_id, []);
    byUser.get(m.user_id)!.push(m);
  }
  return Array.from(byUser.entries())
    .map(([user_id, msgs]) => ({ user_id, msgs }))
    .sort((a, b) => {
      const aLast = a.msgs[a.msgs.length - 1]?.created_at ?? 0;
      const bLast = b.msgs[b.msgs.length - 1]?.created_at ?? 0;
      return bLast - aLast;
    });
})();

function shortZitaUser(id: string): string {
  return id.length > 8 ? `${id.slice(0, 8)}…` : id;
}

// --- Derive groupings + display values ---------------------------------

function safeJson(input: string | null | undefined): any {
  if (!input) return {};
  try { return JSON.parse(input); } catch { return {}; }
}

function parseStringArray(notes: string | null): string[] {
  if (!notes) return [];
  try {
    const parsed = JSON.parse(notes);
    if (Array.isArray(parsed)) return parsed.filter((x) => typeof x === 'string');
    return [];
  } catch { return []; }
}

type Claim = { claim: string; status?: string; note?: string };
function parseClaims(notes: string | null): Claim[] {
  if (!notes) return [];
  try {
    const parsed = JSON.parse(notes);
    if (!Array.isArray(parsed)) return [];
    return parsed
      .filter((c) => c && typeof c === 'object' && typeof c.claim === 'string')
      .map((c: any) => ({
        claim: c.claim,
        status: typeof c.status === 'string' ? c.status : undefined,
        note: typeof c.note === 'string' ? c.note : undefined,
      }));
  } catch { return []; }
}

function roundFromDraftId(draftId: string): number {
  const m = draftId.match(/-r(\d+)$/);
  return m ? parseInt(m[1], 10) : 1;
}

// Group audits by draft_id (one round = one draft_id).
const roundsMap = new Map<string, AuditRow[]>();
for (const a of audits) {
  if (!roundsMap.has(a.draft_id)) roundsMap.set(a.draft_id, []);
  roundsMap.get(a.draft_id)!.push(a);
}
const rounds = Array.from(roundsMap.entries())
  .map(([draftId, group]) => ({
    round: roundFromDraftId(draftId),
    voice: group.find((g) => g.auditor === 'voice'),
    structure: group.find((g) => g.auditor === 'structure'),
    fact: group.find((g) => g.auditor === 'fact'),
  }))
  .sort((a, b) => a.round - b.round);

// Pipeline timeline: one row per step (collapse running/done pairs).
type TimelineRow = { step: string; status: string; data: any; tMs: number };
const stepMap = new Map<string, TimelineRow>();
const stepOrder: string[] = [];
for (const p of pipeline) {
  const row: TimelineRow = { step: p.step, status: p.status, data: safeJson(p.data), tMs: p.created_at };
  if (!stepMap.has(p.step)) {
    stepOrder.push(p.step);
    stepMap.set(p.step, row);
    continue;
  }
  const prev = stepMap.get(p.step)!;
  const prevTerminal = prev.status !== 'running';
  const thisTerminal = row.status !== 'running';
  if (thisTerminal || (!prevTerminal && row.tMs > prev.tMs)) stepMap.set(p.step, row);
}
const timeline = stepOrder.map((s) => stepMap.get(s)!);

// Pipeline metadata derived from publishing.done.
const publishStep = pipeline.find((p) => p.step === 'publishing' && p.status === 'done');
const publishData = publishStep ? safeJson(publishStep.data) : {};
const commitUrl: string | null = publishData.commitUrl ?? null;
const filePath: string | null = publishData.filePath ?? null;

const tier = piece ? auditTier(piece.voice_score, piece.quality_flag) : null;

const pickedCandidate = candidates.find((c) => c.selected === 1);
const otherCandidates = candidates.filter((c) => c.selected !== 1);

function relativeFromStart(tMs: number, startMs: number): string {
  const diff = tMs - startMs;
  if (diff <= 0) return 'start';
  const secs = Math.floor(diff / 1000);
  if (secs < 60) return `+${secs}s`;
  const mins = Math.floor(secs / 60);
  if (mins < 60) return `+${mins}m`;
  const hrs = Math.floor(mins / 60);
  return `+${hrs}h ${mins % 60}m`;
}

const timelineStart = timeline[0]?.tMs ?? 0;

// Audio state — decides whether to show per-beat rows, retry affordance, or both.
// Failure detection is scoped to the CURRENT audio attempt: find the most
// recent `audio-producing running` timestamp and only consider audio-*
// failures at or after that point. Without this bound, stale historical
// failures surface as if they were current — e.g. during a Start-over
// run (has_audio=0, retry block visible), a `Durable Object reset`
// failure from a prior day's run would display as the current reason.
// Bug pre-existing since commit 3208c86 (2026-04-22); surfaced during
// 2026-04-23 testing of the always-visible retry surface.
const latestAudioRunStart = pipeline
  .filter((p) => p.step === 'audio-producing' && p.status === 'running')
  .reduce<number>((max, p) => (p.created_at > max ? p.created_at : max), 0);
const audioFailureStep = pipeline.find(
  (p) => (p.step === 'audio-producing' || p.step === 'audio-auditing' || p.step === 'audio-publishing')
    && p.status === 'failed'
    && p.created_at >= latestAudioRunStart,
);
const audioFailureReason: string | null = audioFailureStep
  ? (safeJson(audioFailureStep.data)?.reason ?? null)
  : null;
const totalAudioChars = audioRows.reduce((sum, r) => sum + r.character_count, 0);
// has_audio = 1 is the definitive "audio done" signal (set by Publisher
// after the second commit splices audioBeats into frontmatter). Any
// other state (partial rows, failed step, zero rows, stalled with no
// error) means a retry affordance should be visible.
const audioComplete = piece?.has_audio === 1;
// Expected beat count for the piece. beat_count on daily_pieces is the
// Drafter's declared value; fall back to row count if unset (older
// pieces from before beat_count was populated).
const expectedBeats = piece?.beat_count ?? audioRows.length;

// Compact summary values — computed once, consumed in the top stat row
// and in each collapsible section's <summary> so the operator can scan
// everything worth knowing before expanding any forensic block.
const audioStatusLabel: string = audioComplete
  ? 'complete'
  : audioRows.length > 0
    ? `partial (${audioRows.length}/${expectedBeats})`
    : audioFailureStep
      ? 'failed'
      : 'pending';
const eventsWarn = observerEvents.filter((e) => e.severity === 'warn').length;
const eventsEscalation = observerEvents.filter((e) => e.severity === 'escalation').length;
const zitaTotalMsgs = zitaMessages.length;
const finalRound = rounds[rounds.length - 1];
const finalVoice: number | null | undefined = finalRound?.voice?.score;
const pickedHeadline: string | null = pickedCandidate?.headline ?? null;

function publishedDisplay(): string {
  if (!piece?.published_at) return '';
  const d = new Date(piece.published_at);
  return d.toLocaleString('en-GB', { dateStyle: 'medium', timeStyle: 'short' });
}
---

<BaseLayout title={`${piece?.headline ?? date} — Admin · Zeemish`}>

  <nav class="text-sm text-zee-muted mb-6 pt-6" aria-label="Breadcrumb">
    <a href="/dashboard/admin/" class="hover:text-zee-primary transition-colors">Admin</a>
    <span class="mx-2 opacity-50">/</span>
    <a href={`/dashboard/admin/piece/${date}/`} class="hover:text-zee-primary transition-colors">{date}</a>
    <span class="mx-2 opacity-50">/</span>
    <span class="text-zee-text">{slug}</span>
  </nav>

  {!piece ? (
    <div class="py-12">
      <p class="text-xs font-semibold uppercase tracking-widest text-zee-gold mb-2">No piece</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-3 leading-tight tracking-tight">{date}</h1>
      <p class="text-lg text-zee-muted">No piece was published on this date.</p>
      {pipeline.length > 0 && (
        <p class="text-sm text-zee-muted mt-3">A pipeline run exists ({pipeline.length} steps) but no row in <code class="text-xs">daily_pieces</code> — likely scanner skipped or pipeline errored before publishing.</p>
      )}
    </div>
  ) : (
    <>
      <div class="pb-8">
        <p class="text-xs font-semibold uppercase tracking-widest text-zee-gold mb-2">
          {tier ? auditTierLabel(tier).toUpperCase() : 'PIECE'}
        </p>
        <h1 class="text-3xl md:text-4xl font-bold mb-3 leading-tight tracking-tight">{piece.headline}</h1>
        {piece.underlying_subject && (
          <p class="text-lg text-zee-muted mb-4">{piece.underlying_subject}</p>
        )}
        <p class="text-sm text-zee-muted flex flex-wrap items-center gap-x-2 gap-y-1">
          {piece.voice_score != null && <><span>Voice {piece.voice_score}/100</span><span class="opacity-40">·</span></>}
          {piece.word_count != null && <><span>{piece.word_count} words</span><span class="opacity-40">·</span></>}
          {piece.beat_count != null && <><span>{piece.beat_count} beats</span><span class="opacity-40">·</span></>}
          {rounds.length > 0 && <><span>{rounds.length} round{rounds.length === 1 ? '' : 's'}</span><span class="opacity-40">·</span></>}
          {piece.fact_check_passed != null && <><span>Facts {piece.fact_check_passed ? 'passed' : 'failed'}</span><span class="opacity-40">·</span></>}
          <span>Audio {audioStatusLabel}</span>
          <span class="opacity-40">·</span>
          <span>{observerEvents.length} event{observerEvents.length === 1 ? '' : 's'}</span>
          <span class="opacity-40">·</span>
          <span>{zitaTotalMsgs} Zita msg{zitaTotalMsgs === 1 ? '' : 's'}</span>
          <span class="opacity-40">·</span>
          <span>{candidates.length} candidate{candidates.length === 1 ? '' : 's'}</span>
          <span class="opacity-40">·</span>
          <span>Published {publishedDisplay()}</span>
          {piece.quality_flag === 'low' && <><span class="opacity-40">·</span><span class="text-zee-gold font-medium">FLAGGED LOW</span></>}
        </p>
        <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
          <a href={pieceUrl(date, slug)} class="text-zee-primary hover:underline">View on site →</a>
          {commitUrl && (
            <a href={commitUrl} target="_blank" rel="noopener" class="text-zee-primary hover:underline">View commit on GitHub →</a>
          )}
          {piece.source_story && (
            <a href={piece.source_story} target="_blank" rel="noopener" class="text-zee-muted hover:text-zee-primary truncate max-w-xs">Source →</a>
          )}
        </div>
      </div>

      <!-- Pipeline timeline -->
      {timeline.length > 0 && (
        <section class="mb-10">
          <details class="group">
            <summary class="flex items-baseline justify-between gap-4 mb-4 cursor-pointer list-none py-1">
              <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted">Pipeline timeline</h2>
              <span class="flex items-center gap-2 text-xs text-zee-muted tabular-nums">
                <span>{timeline.length} step{timeline.length === 1 ? '' : 's'}</span>
                <span class="text-zee-muted/60 group-open:rotate-90 transition-transform" aria-hidden="true">▸</span>
              </span>
            </summary>
            <ol class="space-y-1.5">
            {timeline.map((s) => {
              const ok = s.status === 'done';
              const failed = s.status === 'failed' || s.status === 'error';
              const dotCls = ok ? 'bg-zee-primary' : failed ? 'bg-zee-gold' : 'border border-zee-border bg-transparent';
              const detailBits: string[] = [];
              const d = s.data ?? {};
              if (d.candidateCount != null) detailBits.push(`${d.candidateCount} candidates`);
              if (d.headline) detailBits.push(`"${d.headline}"`);
              if (d.subject) detailBits.push(d.subject);
              if (d.wordCount != null) detailBits.push(`${d.wordCount} words · ${d.beatCount ?? '?'} beats`);
              if (d.voiceScore != null) {
                const bits = [`Voice ${d.voiceScore}/100`];
                if (d.factsPassed != null) bits.push(`Facts ${d.factsPassed ? '✓' : '✗'}`);
                if (d.structurePassed != null) bits.push(`Structure ${d.structurePassed ? '✓' : '✗'}`);
                detailBits.push(bits.join(' · '));
              }
              if (d.failedGates) detailBits.push(`failed: ${d.failedGates.join(', ')}`);
              if (d.qualityFlag === 'low') detailBits.push('flagged low');
              if (d.error) detailBits.push(`error: ${d.error}`);
              return (
                <li>
                  <details class="group">
                    <summary class="flex items-start gap-3 py-1.5 cursor-pointer list-none">
                      <span class={`w-2 h-2 rounded-full ${dotCls} mt-2 shrink-0`} aria-hidden="true"></span>
                      <div class="flex-1 min-w-0">
                        <div class="flex flex-wrap items-baseline gap-x-2 text-sm">
                          <span class="font-medium">{pipelineStepLabel(s.step)}</span>
                          <span class="text-xs text-zee-muted tabular-nums">{relativeFromStart(s.tMs, timelineStart)}</span>
                        </div>
                        {detailBits.length > 0 && (
                          <p class="text-xs text-zee-muted mt-0.5 leading-relaxed">{detailBits.join(' · ')}</p>
                        )}
                      </div>
                      <span class="text-xs text-zee-muted/60 group-open:rotate-90 transition-transform shrink-0 mt-1.5" aria-hidden="true">▸</span>
                    </summary>
                    <pre class="mt-2 ml-5 p-3 bg-zee-border/30 rounded text-[11px] text-zee-text overflow-x-auto leading-snug">{JSON.stringify(s.data, null, 2)}</pre>
                  </details>
                </li>
              );
            })}
            </ol>
          </details>
        </section>
      )}

      <!-- Audit rounds -->
      {rounds.length > 0 && (
        <section class="mb-10">
          <details class="group">
            <summary class="flex items-baseline justify-between gap-4 mb-4 cursor-pointer list-none py-1">
              <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted">Audit rounds</h2>
              <span class="flex items-center gap-2 text-xs text-zee-muted tabular-nums">
                <span>{rounds.length} round{rounds.length === 1 ? '' : 's'}{finalVoice != null && <> · final voice {finalVoice}/100</>}</span>
                <span class="text-zee-muted/60 group-open:rotate-90 transition-transform" aria-hidden="true">▸</span>
              </span>
            </summary>
            <div class="space-y-4">
            {rounds.map((r, i) => {
              const isFinal = i === rounds.length - 1;
              const voiceVio = parseStringArray(r.voice?.notes ?? null);
              const structIssues = parseStringArray(r.structure?.notes ?? null);
              const claims = parseClaims(r.fact?.notes ?? null);
              return (
                <div class="border border-zee-border rounded-xl p-4 md:p-5">
                  <div class="flex items-center justify-between gap-2 mb-3 pb-3 border-b border-zee-border/60">
                    <span class="font-medium text-sm">{isFinal ? `Round ${r.round} (final)` : `Round ${r.round}`}</span>
                    <span class="text-xs text-zee-muted tabular-nums">{voiceVio.length + structIssues.length + claims.length} notes</span>
                  </div>

                  <div class="space-y-4">
                    <!-- Voice -->
                    <div>
                      <div class="flex items-baseline justify-between mb-1.5">
                        <span class="text-[10px] font-bold uppercase tracking-widest text-zee-muted">Voice</span>
                        <span class="text-sm font-medium">
                          {r.voice?.score != null ? `${r.voice.score}/100` : '—'}
                          <span class={`ml-2 text-xs ${r.voice?.passed ? 'text-zee-primary' : 'text-zee-muted'}`}>
                            {r.voice?.passed ? 'passed' : 'below bar'}
                          </span>
                        </span>
                      </div>
                      {voiceVio.length === 0 ? (
                        <p class="text-xs text-zee-muted italic">No violations flagged.</p>
                      ) : (
                        <ul class="text-xs text-zee-text space-y-1 ml-1">
                          {voiceVio.map((v) => <li class="leading-relaxed">— {v}</li>)}
                        </ul>
                      )}
                    </div>

                    <!-- Facts -->
                    <div class="pt-3 border-t border-zee-border/60">
                      <div class="flex items-baseline justify-between mb-1.5">
                        <span class="text-[10px] font-bold uppercase tracking-widest text-zee-muted">Facts</span>
                        <span class={`text-sm font-medium ${r.fact?.passed ? 'text-zee-primary' : 'text-zee-muted'}`}>
                          {r.fact?.passed ? 'passed' : 'mixed'}
                        </span>
                      </div>
                      {claims.length === 0 ? (
                        <p class="text-xs text-zee-muted italic">No claims reviewed.</p>
                      ) : (
                        <ul class="text-xs text-zee-text space-y-2 ml-1">
                          {claims.map((c) => (
                            <li class="leading-relaxed">
                              <span class="block">{c.claim}</span>
                              {(c.status || c.note) && (
                                <span class="block text-zee-muted mt-0.5">
                                  {c.status && <span class="uppercase tracking-wide text-[10px] mr-2">{c.status}</span>}
                                  {c.note}
                                </span>
                              )}
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>

                    <!-- Structure -->
                    <div class="pt-3 border-t border-zee-border/60">
                      <div class="flex items-baseline justify-between mb-1.5">
                        <span class="text-[10px] font-bold uppercase tracking-widest text-zee-muted">Structure</span>
                        <span class={`text-sm font-medium ${r.structure?.passed ? 'text-zee-primary' : 'text-zee-muted'}`}>
                          {r.structure?.passed ? 'passed' : 'mixed'}
                        </span>
                      </div>
                      {structIssues.length === 0 ? (
                        <p class="text-xs text-zee-muted italic">No structural issues.</p>
                      ) : (
                        <ul class="text-xs text-zee-text space-y-1 ml-1">
                          {structIssues.map((s) => <li class="leading-relaxed">— {s}</li>)}
                        </ul>
                      )}
                    </div>
                  </div>
                </div>
              );
            })}
            </div>
          </details>
        </section>
      )}

      <!-- Audio -->
      {/* Smart-open when !audioComplete so retry affordance is one click away
          on the broken path. Collapsed when audio is complete — the stat row
          at the top already surfaces "Audio complete". */}
      <section class="mb-10">
        <details class="group" open={!audioComplete}>
          <summary class="flex items-baseline justify-between gap-4 mb-4 cursor-pointer list-none py-1">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted">Audio</h2>
            <span class="flex items-center gap-2 text-xs tabular-nums">
              {audioComplete ? (
                <span class="text-zee-muted">
                  {audioRows.length} beat{audioRows.length === 1 ? '' : 's'} · {totalAudioChars.toLocaleString()} chars · <span class="text-zee-primary">published ✓</span>
                </span>
              ) : audioRows.length > 0 ? (
                <span class="text-zee-gold">
                  {audioRows.length}/{expectedBeats} beats · partial
                </span>
              ) : (
                <span class="text-zee-muted">
                  {audioFailureStep ? 'failed' : 'pending'}
                </span>
              )}
              <span class="text-zee-muted/60 group-open:rotate-90 transition-transform" aria-hidden="true">▸</span>
            </span>
          </summary>

        {/* Row listing — shown whenever any rows exist. Each row has a
            per-beat "Regenerate" button that deletes one R2 object + one
            D1 row and re-runs the pipeline with force=true; producer's
            head-check means only the deleted beat regenerates. */}
        {audioRows.length > 0 && pieceId && (
          <div class={`border border-zee-border rounded-xl p-4 md:p-5 mb-3`}>
            <p class="text-xs text-zee-muted mb-3">
              <span class="font-medium text-zee-text">{audioRows[0].model}</span>
              <span class="opacity-40 mx-2">·</span>
              voice <code class="text-[11px] bg-zee-border/40 px-1 rounded">{audioRows[0].voice_id}</code>
            </p>
            <ul class="divide-y divide-zee-border/60 text-sm">
              {audioRows.map((r) => (
                <li class="py-2 flex items-center gap-3">
                  <a href={r.public_url} target="_blank" rel="noopener" class="font-medium text-zee-primary hover:underline truncate flex-1 min-w-0">
                    {r.beat_name}
                  </a>
                  <span class="text-xs text-zee-muted tabular-nums shrink-0">
                    {r.character_count.toLocaleString()} chars
                  </span>
                  <button
                    type="button"
                    class="audio-regen-beat-btn text-[11px] px-2 py-1 border border-zee-border rounded hover:bg-zee-border/30 transition-colors shrink-0"
                    data-piece-id={pieceId}
                    data-beat={r.beat_name}
                  >
                    Regenerate
                  </button>
                </li>
              ))}
            </ul>
            <p class="text-xs text-zee-muted mt-3 leading-relaxed">
              Per-beat regen deletes just that clip and re-runs the pipeline. Other beats keep playing for readers. Cloudflare cache may serve the old clip for a short window — hard-refresh to confirm.
            </p>
            <p id="audio-beat-status" class="text-xs text-zee-muted mt-2"></p>
          </div>
        )}

        {/* Whole-piece retry block. Behaviour gated on has_audio:
            - complete (has_audio=1): Start over only. Continue is meaningless
              when every beat already exists on R2.
            - incomplete with rows: Continue + Start over (today's behaviour).
            - incomplete with no rows: Retry audio only. */}
        <div class="border border-zee-border rounded-xl p-4 md:p-5">
          {audioComplete ? (
            <p class="text-sm text-zee-text mb-4">
              <span class="text-zee-primary font-medium">Audio published ✓</span> — use <strong>Start over</strong> to force a full rewrite (e.g. after a normaliser change), or the per-beat <strong>Regenerate</strong> buttons above for a surgical fix.
            </p>
          ) : audioFailureReason ? (
            <>
              <p class="text-sm text-zee-text mb-2">
                <span class="text-zee-gold font-medium">Audio pipeline failed</span> at <code class="text-xs bg-zee-border/40 px-1 rounded">{audioFailureStep?.step}</code>.
              </p>
              <p class="text-xs text-zee-muted mb-4 leading-relaxed">{audioFailureReason}</p>
            </>
          ) : audioRows.length > 0 ? (
            <p class="text-sm text-zee-text mb-4">
              <span class="text-zee-gold font-medium">Audio incomplete</span> — expected {expectedBeats} beat{expectedBeats === 1 ? '' : 's'}, have {audioRows.length}. The pipeline may have stalled without recording an error.
            </p>
          ) : (
            <p class="text-sm text-zee-muted mb-4 italic">
              No audio yet for this piece. Run the audio pipeline from here.
            </p>
          )}
          <div class="flex flex-wrap items-center gap-3">
            {!audioComplete && (
              <button
                id="audio-retry-btn"
                data-date={date}
                data-piece-id={pieceId}
                data-mode="continue"
                class="px-4 py-2 bg-zee-primary text-white rounded-lg text-sm font-medium hover:opacity-90 transition-opacity"
              >
                {audioRows.length > 0 ? 'Continue' : 'Retry audio'}
              </button>
            )}
            {audioRows.length > 0 && (
              <button
                id="audio-retry-fresh-btn"
                data-date={date}
                data-piece-id={pieceId}
                data-mode="fresh"
                data-count={audioRows.length}
                data-audio-complete={audioComplete ? '1' : '0'}
                class="px-4 py-2 border border-zee-border text-zee-text rounded-lg text-sm font-medium hover:bg-zee-border/20 transition-colors"
              >
                Start over
              </button>
            )}
            <span id="audio-retry-status" class="text-xs text-zee-muted"></span>
          </div>
          {audioRows.length > 0 && (
            <p class="text-xs text-zee-muted mt-3 leading-relaxed">
              {!audioComplete && (
                <>
                  <strong class="text-zee-text">Continue</strong> resumes where the prior attempt stopped — reuses the {audioRows.length} existing clip{audioRows.length === 1 ? '' : 's'}.
                  <span class="mx-1">·</span>
                </>
              )}
              <strong class="text-zee-text">Start over</strong> wipes all existing clips + D1 rows and regenerates every beat from scratch.{audioComplete && ' Readers will briefly have no audio until the pipeline completes.'}
            </p>
          )}
          </div>
        </details>
      </section>

      <!-- Scanner candidates -->
      {candidates.length > 0 && (
        <section class="mb-10">
          <details class="group">
            <summary class="flex items-baseline justify-between gap-4 mb-4 cursor-pointer list-none py-1">
              <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted">Scanner candidates</h2>
              <span class="flex items-center gap-2 text-xs text-zee-muted tabular-nums">
                <span>
                  {candidates.length} candidate{candidates.length === 1 ? '' : 's'}
                  {pickedHeadline && <> · picked: "{pickedHeadline.length > 60 ? pickedHeadline.slice(0, 60) + '…' : pickedHeadline}"</>}
                </span>
                <span class="text-zee-muted/60 group-open:rotate-90 transition-transform" aria-hidden="true">▸</span>
              </span>
            </summary>
            <p class="text-sm text-zee-muted mb-4">Sorted by teachability score. Picked candidate marked with a teal dot.</p>
            <ul class="divide-y divide-zee-border/60">
            {[pickedCandidate, ...otherCandidates].filter((c): c is CandidateRow => !!c).map((c) => {
              const isPicked = c.selected === 1;
              return (
                <li class="py-3 flex items-start gap-3">
                  <span class={`w-2 h-2 rounded-full mt-2 shrink-0 ${isPicked ? 'bg-zee-primary' : 'border border-zee-border bg-transparent'}`} aria-hidden="true"></span>
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-baseline gap-x-2 text-xs text-zee-muted tabular-nums">
                      {c.teachability_score != null && <span class="text-zee-text font-medium">{c.teachability_score}</span>}
                      {c.source && (<><span class="opacity-40">·</span><span>{c.source}</span></>)}
                      {c.category && (<><span class="opacity-40">·</span><span>{c.category}</span></>)}
                      {isPicked && (<><span class="opacity-40">·</span><span class="text-zee-primary font-medium">picked</span></>)}
                    </div>
                    <p class="mt-1 text-sm leading-snug">
                      {c.url ? (
                        <a href={c.url} target="_blank" rel="noopener" class="hover:text-zee-primary transition-colors">{c.headline}</a>
                      ) : c.headline}
                    </p>
                    {/* Summary intentionally not shown. RSS items'
                        descriptions are headline + source restated +
                        google news anchor markup — they add no info
                        beyond the row above. */}
                  </div>
                </li>
              );
            })}
            </ul>
          </details>
        </section>
      )}

      <!-- Zita conversations for this piece -->
      {zitaConvos.length > 0 && (
        <section class="mb-10">
          <details class="group">
            <summary class="flex items-baseline justify-between gap-4 mb-4 cursor-pointer list-none py-1">
              <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted">Questions from readers</h2>
              <span class="flex items-center gap-2 text-xs text-zee-muted tabular-nums">
                <span>{zitaConvos.length} convo{zitaConvos.length === 1 ? '' : 's'} · {zitaTotalMsgs} message{zitaTotalMsgs === 1 ? '' : 's'}</span>
                <span class="text-zee-muted/60 group-open:rotate-90 transition-transform" aria-hidden="true">▸</span>
              </span>
            </summary>
            <div class="flex items-center gap-4 text-xs mb-4">
              <button
                id="zita-synth-btn"
                data-date={date}
                class="text-zee-primary hover:underline"
              >Run synthesis</button>
              <span id="zita-synth-status" class="text-zee-muted"></span>
              <a href="/dashboard/admin/zita/" class="text-zee-primary hover:underline">All Zita activity →</a>
            </div>
            <div class="space-y-3">
            {zitaConvos.map((c) => (
              <details class="p-4 rounded-xl border border-zee-border group">
                <summary class="cursor-pointer list-none">
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <div class="flex items-center gap-3">
                      <span class="text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded bg-zee-primary/10 text-zee-primary tabular-nums">{c.msgs.length}&nbsp;msgs</span>
                      <span class="text-xs text-zee-muted tabular-nums">{shortZitaUser(c.user_id)}</span>
                    </div>
                    <span class="text-xs text-zee-muted group-open:hidden">Expand</span>
                    <span class="text-xs text-zee-muted hidden group-open:inline">Collapse</span>
                  </div>
                </summary>
                <div class="mt-4 pt-4 border-t border-zee-border/60 space-y-2">
                  {c.msgs.map((m) => (
                    <div class={m.role === 'user' ? 'text-sm' : 'text-sm text-zee-muted'}>
                      <span class="text-[10px] font-semibold uppercase tracking-wider mr-2">
                        {m.role === 'user' ? 'reader' : 'zita'}
                      </span>
                      <span class="whitespace-pre-wrap">{m.content}</span>
                    </div>
                  ))}
                </div>
              </details>
            ))}
            </div>
          </details>
        </section>
      )}

      <!-- Observer events -->
      {observerEvents.length > 0 && (
        <section class="mb-10">
          <details class="group">
            <summary class="flex items-baseline justify-between gap-4 mb-4 cursor-pointer list-none py-1">
              <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted">Observer events this day</h2>
              <span class="flex items-center gap-2 text-xs text-zee-muted tabular-nums">
                <span>
                  {observerEvents.length} event{observerEvents.length === 1 ? '' : 's'}
                  {eventsWarn > 0 && <> · <span class="text-zee-text">{eventsWarn} warn</span></>}
                  {eventsEscalation > 0 && <> · <span class="text-zee-gold">{eventsEscalation} escalation</span></>}
                </span>
                <span class="text-zee-muted/60 group-open:rotate-90 transition-transform" aria-hidden="true">▸</span>
              </span>
            </summary>
            <div class="space-y-3">
            {observerEvents.map((e) => (
              <div class={`p-4 rounded-xl border ${
                !e.acknowledged_at
                  ? e.severity === 'escalation' ? 'border-zee-gold/40 bg-zee-gold/5'
                    : e.severity === 'warn' ? 'border-zee-muted/30 bg-zee-border/20'
                    : 'border-zee-primary/20 bg-zee-primary/5'
                  : 'border-zee-border'
              }`}>
                <div class="flex items-center justify-between mb-2">
                  <div class="flex items-center gap-2">
                    <span class={`text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded ${
                      e.severity === 'escalation' ? 'bg-zee-gold/15 text-zee-gold' :
                      e.severity === 'warn' ? 'bg-zee-muted/20 text-zee-text' :
                      'bg-zee-primary/10 text-zee-primary'
                    }`}>{e.severity}</span>
                    <span class="text-xs text-zee-muted tabular-nums">{new Date(e.created_at).toLocaleString()}</span>
                  </div>
                  {e.acknowledged_at && (
                    <span class="text-xs text-zee-muted">acked</span>
                  )}
                </div>
                <h3 class="font-medium text-sm">{e.title}</h3>
                <p class="text-sm text-zee-muted mt-1 leading-relaxed">{e.body}</p>
                {e.context && (
                  <details class="mt-2">
                    <summary class="text-xs text-zee-primary hover:underline cursor-pointer">context</summary>
                    <pre class="mt-2 p-3 bg-zee-border/30 rounded text-[11px] overflow-x-auto leading-snug">{e.context}</pre>
                  </details>
                )}
              </div>
            ))}
            </div>
          </details>
        </section>
      )}

      <!-- Raw data dumps -->
      <section class="mb-10">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">Raw data</h2>
        <p class="text-sm text-zee-muted mb-3">Honest debugging when summaries hide something.</p>
        <details class="border border-zee-border rounded-xl mb-2">
          <summary class="text-sm font-medium px-4 py-3 cursor-pointer hover:bg-zee-border/30 transition-colors">
            daily_pieces row
          </summary>
          <pre class="px-4 pb-4 text-[11px] overflow-x-auto leading-snug">{JSON.stringify(piece, null, 2)}</pre>
        </details>
        <details class="border border-zee-border rounded-xl mb-2">
          <summary class="text-sm font-medium px-4 py-3 cursor-pointer hover:bg-zee-border/30 transition-colors">
            audit_results rows ({audits.length})
          </summary>
          <pre class="px-4 pb-4 text-[11px] overflow-x-auto leading-snug">{JSON.stringify(audits, null, 2)}</pre>
        </details>
        <details class="border border-zee-border rounded-xl mb-2">
          <summary class="text-sm font-medium px-4 py-3 cursor-pointer hover:bg-zee-border/30 transition-colors">
            pipeline_log rows ({pipeline.length})
          </summary>
          <pre class="px-4 pb-4 text-[11px] overflow-x-auto leading-snug">{JSON.stringify(pipeline.map((p) => ({ ...p, data: safeJson(p.data) })), null, 2)}</pre>
        </details>
        {filePath && (
          <p class="text-xs text-zee-muted mt-3">
            MDX path: <code class="bg-zee-border/40 px-1 rounded">{filePath}</code>
          </p>
        )}
      </section>
    </>
  )}
</BaseLayout>

<script>
  // Three retry paths:
  //   - "Continue" (resume from where it stopped) — only shown when audio
  //     is incomplete; has_audio=1 guard on the backend refuses otherwise.
  //   - "Start over" (wipe existing R2 + D1 rows, regenerate all) — always
  //     available when any audio rows exist. Confirm() dialog warns
  //     about cost AND (on complete pieces) reader-visible downtime.
  //   - "Regenerate" per beat — deletes one R2 object + one D1 row, leaves
  //     has_audio=1 so other beats keep playing, regenerates just that
  //     beat via producer's R2 head-check. Surgical fix path.
  const continueBtn = document.getElementById('audio-retry-btn') as HTMLButtonElement | null;
  const freshBtn = document.getElementById('audio-retry-fresh-btn') as HTMLButtonElement | null;
  const statusEl = document.getElementById('audio-retry-status');
  const beatStatusEl = document.getElementById('audio-beat-status');
  const beatBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.audio-regen-beat-btn'));

  function buildRetryUrl(btn: HTMLButtonElement, extraParams: Record<string, string> = {}) {
    const pieceId = btn.dataset.pieceId;
    const date = btn.dataset.date;
    const qs = new URLSearchParams(extraParams);
    if (pieceId) qs.set('piece_id', pieceId);
    else if (date) qs.set('date', date);
    return `/api/agents/audio-retry?${qs.toString()}`;
  }

  async function runRetry(btn: HTMLButtonElement, mode: 'continue' | 'fresh') {
    if (!statusEl) return;

    if (mode === 'fresh') {
      const count = btn.dataset.count ?? '0';
      const audioComplete = btn.dataset.audioComplete === '1';
      const tail = audioComplete
        ? ' Readers will have NO audio on this piece until regen completes (~2–5 minutes).'
        : '';
      const msg = `Start over will DELETE ${count} existing audio clip${count === '1' ? '' : 's'} and their R2 objects, then regenerate every beat from scratch. This costs ElevenLabs credits.${tail} Continue?`;
      if (!window.confirm(msg)) return;
    }

    // Lock both whole-piece buttons while the request is in flight
    if (continueBtn) continueBtn.disabled = true;
    if (freshBtn) freshBtn.disabled = true;
    statusEl.textContent = mode === 'fresh' ? 'Wiping and regenerating…' : 'Starting…';

    try {
      const res = await fetch(buildRetryUrl(btn, { mode }), { method: 'POST' });
      if (!res.ok) {
        let detail = res.statusText;
        try {
          const body = await res.json() as { error?: string };
          if (body.error) detail = body.error;
        } catch { /* not JSON */ }
        statusEl.textContent = `Failed: ${res.status} ${detail}`;
        if (continueBtn) continueBtn.disabled = false;
        if (freshBtn) freshBtn.disabled = false;
        return;
      }
      statusEl.textContent = 'Started — refresh in a minute to see results.';
      setTimeout(() => window.location.reload(), 60_000);
    } catch (err) {
      const msg = err instanceof Error ? err.message : 'Network error';
      statusEl.textContent = `Failed: ${msg}`;
      if (continueBtn) continueBtn.disabled = false;
      if (freshBtn) freshBtn.disabled = false;
    }
  }

  continueBtn?.addEventListener('click', () => runRetry(continueBtn, 'continue'));
  freshBtn?.addEventListener('click', () => runRetry(freshBtn, 'fresh'));

  for (const beatBtn of beatBtns) {
    beatBtn.addEventListener('click', async () => {
      if (!beatStatusEl) return;
      const beat = beatBtn.dataset.beat ?? '';
      const pieceId = beatBtn.dataset.pieceId ?? '';
      if (!beat || !pieceId) {
        beatStatusEl.textContent = 'Missing beat or piece_id — button is misconfigured.';
        return;
      }
      const msg = `Regenerate audio for beat "${beat}"? This deletes the existing clip and costs ElevenLabs credits. Cloudflare cache may serve the old clip briefly — hard-refresh to hear the new one.`;
      if (!window.confirm(msg)) return;

      beatBtns.forEach((b) => { b.disabled = true; });
      beatStatusEl.textContent = `Regenerating "${beat}"…`;

      try {
        const qs = new URLSearchParams({ mode: 'beat', piece_id: pieceId, beat });
        const res = await fetch(`/api/agents/audio-retry?${qs.toString()}`, { method: 'POST' });
        if (!res.ok) {
          let detail = res.statusText;
          try {
            const body = await res.json() as { error?: string };
            if (body.error) detail = body.error;
          } catch { /* not JSON */ }
          beatStatusEl.textContent = `Failed: ${res.status} ${detail}`;
          beatBtns.forEach((b) => { b.disabled = false; });
          return;
        }
        beatStatusEl.textContent = `Started — refresh in a minute to see the updated "${beat}".`;
        setTimeout(() => window.location.reload(), 60_000);
      } catch (err) {
        const msg = err instanceof Error ? err.message : 'Network error';
        beatStatusEl.textContent = `Failed: ${msg}`;
        beatBtns.forEach((b) => { b.disabled = false; });
      }
    });
  }

  // Zita-synthesis manual trigger — fires Learner.analyseZitaPatternsDaily
  // for this piece without waiting for the 01:45 UTC day+1 alarm. The
  // ≥5-user-message guard still applies server-side; below threshold
  // the call completes as an observer "skipped" info event.
  const synthBtn = document.getElementById('zita-synth-btn') as HTMLButtonElement | null;
  const synthStatus = document.getElementById('zita-synth-status');

  synthBtn?.addEventListener('click', async () => {
    if (!synthStatus) return;
    const date = synthBtn.dataset.date;
    if (!date) return;
    synthBtn.disabled = true;
    synthStatus.textContent = 'Starting…';
    try {
      const res = await fetch(`/api/agents/zita-synthesis-trigger?date=${date}`, { method: 'POST' });
      if (!res.ok) {
        let detail = res.statusText;
        try {
          const body = await res.json() as { error?: string };
          if (body.error) detail = body.error;
        } catch { /* not JSON */ }
        synthStatus.textContent = `Failed: ${res.status} ${detail}`;
        synthBtn.disabled = false;
        return;
      }
      synthStatus.textContent = 'Started — check Observer events in ~10s.';
    } catch (err) {
      const msg = err instanceof Error ? err.message : 'Network error';
      synthStatus.textContent = `Failed: ${msg}`;
      synthBtn.disabled = false;
    }
  });
</script>
