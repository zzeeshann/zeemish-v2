---
export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getUser } from '../../lib/db';
import { formatDate } from '../../lib/format';
import { auditTier, auditTierLabel } from '../../lib/audit-tier';
import { deriveSlug } from '../../lib/slug';
import { pipelineStepLabel } from '../../lib/pipeline-steps';
import { getLearningCounts, type LearningCounts } from '../../lib/learnings';

const db = Astro.locals.runtime.env.DB;
const userId = Astro.locals.userId;
const user = userId ? await getUser(db, userId) : null;
const ADMIN_EMAIL = (Astro.locals.runtime.env as Record<string, string>).ADMIN_EMAIL;

// Admin gate.
if (!user?.email || user.email !== ADMIN_EMAIL) {
  return Astro.redirect('/login/?redirect=/dashboard/admin/');
}

const today = new Date().toISOString().slice(0, 10);
const nowMs = Date.now();
const WEEK_MS = 7 * 24 * 60 * 60 * 1000;

type Piece = {
  id: string;
  date: string;
  headline: string;
  underlying_subject: string | null;
  voice_score: number | null;
  quality_flag: 'low' | null;
  word_count: number | null;
  beat_count: number | null;
  published_at: number | null;
};

type ObserverEvent = {
  id: string;
  severity: 'info' | 'warn' | 'escalation';
  title: string;
  body: string;
  context: string | null;
  acknowledged_at: number | null;
  created_at: number;
};

let observerEvents: ObserverEvent[] = [];
let allPieces: (Piece & { rounds: number; candidates: number })[] = [];
let lifetimeRuns = 0;
let openEscalations = 0;
let errorsThisWeek = 0;
let observerWarnCount = 0;
let observerEscalationCount = 0;
let avgRevisionsLifetime: number | null = null;
let learningCounts: LearningCounts = { producer: 0, selfReflection: 0, total: 0 };
let pipelineHistory: {
  runId: string;
  pieceId: string | null;
  date: string | null;
  headline: string | null;
  finalStep: string;
  finalStatus: string;
  data: any;
  tMs: number;
}[] = [];

// Content-collection lookup for per-piece admin URLs. The route moved
// to /dashboard/admin/piece/{date}/{slug}/ in Phase 7 — links here need
// to resolve slug per piece, keyed off MDX filename via deriveSlug.
// Fallback to `{date}/` (legacy index) when the collection entry is
// missing — covers the case where daily_pieces has a row but the MDX
// collection hasn't rebuilt yet.
const collectionEntries = await getCollection('dailyPieces');
const slugByDate = new Map<string, string>();
const slugByPieceId = new Map<string, string>();
for (const e of collectionEntries) {
  slugByDate.set(e.data.date, deriveSlug(e.id));
  slugByPieceId.set(e.data.pieceId, deriveSlug(e.id));
}
function adminPieceHref(date: string, pieceId?: string): string {
  const slug = (pieceId && slugByPieceId.get(pieceId)) ?? slugByDate.get(date);
  return slug
    ? `/dashboard/admin/piece/${date}/${slug}/`
    : `/dashboard/admin/piece/${date}/`;
}

type EngagementRow = {
  piece_id: string;
  lesson_id: string;
  piece_date: string | null;
  views: number;
  completions: number;
  audio_plays: number;
  top_drop_off: string | null;
  last_active: string;
};
let engagement: EngagementRow[] = [];

try {
  // Observer events — last 100. The top-level stats already surface
  // what-needs-attention (openEscalations + errorsThisWeek). The feed
  // is the chronological log; at current volume 100 rows ≈ 3-4 weeks
  // of history; at hypothetical 1h cadence with full producer/reflection/
  // Zita synthesis traffic, still ≈ 10 hours. Raised from 30 on 2026-04-22
  // after piece_id threading landed in migration 0020 made cross-piece
  // context more useful to keep loaded.
  const events = await db
    .prepare('SELECT * FROM observer_events ORDER BY created_at DESC LIMIT 100')
    .all<ObserverEvent>();
  observerEvents = events.results;

  openEscalations = observerEvents.filter((e) => e.severity === 'escalation' && !e.acknowledged_at).length;

  // Severity chip counts — drive the chip bar above the feed + its
  // match-this-filter hit counts. Computed against the in-memory slice
  // of 100 rows we already loaded; no extra query.
  observerWarnCount = observerEvents.filter((e) => e.severity === 'warn').length;
  observerEscalationCount = observerEvents.filter((e) => e.severity === 'escalation').length;

  const weekMsAgo = nowMs - WEEK_MS;
  const errs = await db
    .prepare("SELECT COUNT(*) as n FROM observer_events WHERE severity = 'warn' AND created_at > ?")
    .bind(weekMsAgo)
    .first<{ n: number }>();
  errorsThisWeek = errs?.n ?? 0;

  // All pieces newest first. Used for the All Pieces list.
  // ORDER BY date DESC, published_at DESC so same-date pieces (multi-per-day)
  // stay in publish order rather than D1's implicit row order.
  const piecesRes = await db
    .prepare('SELECT id, date, headline, underlying_subject, voice_score, quality_flag, word_count, beat_count, published_at FROM daily_pieces ORDER BY date DESC, published_at DESC')
    .all<Piece>();
  const pieces = piecesRes.results;

  // Round + candidate counts per piece — keyed by piece_id (migration 0018 +
  // 0019 backfill). Pre-0018 this was keyed on `daily/${date}` / `date`,
  // which pooled same-date pieces into one count at multi-per-day cadence.
  const roundsByPiece = new Map<string, number>();
  const candsByPiece = new Map<string, number>();
  if (pieces.length > 0) {
    const pieceIds = pieces.map((p) => p.id);
    const placeholders = pieceIds.map(() => '?').join(',');
    const roundsRes = await db
      .prepare(`SELECT piece_id, draft_id FROM audit_results WHERE piece_id IN (${placeholders})`)
      .bind(...pieceIds)
      .all<{ piece_id: string; draft_id: string }>();
    for (const r of roundsRes.results) {
      const m = r.draft_id.match(/-r(\d+)$/);
      const round = m ? parseInt(m[1], 10) : 1;
      const prev = roundsByPiece.get(r.piece_id) ?? 0;
      if (round > prev) roundsByPiece.set(r.piece_id, round);
    }

    const candsRes = await db
      .prepare(`SELECT piece_id, COUNT(*) as n FROM daily_candidates WHERE piece_id IN (${placeholders}) GROUP BY piece_id`)
      .bind(...pieceIds)
      .all<{ piece_id: string; n: number }>();
    for (const r of candsRes.results) candsByPiece.set(r.piece_id, r.n);
  }

  allPieces = pieces.map((p) => ({
    ...p,
    rounds: roundsByPiece.get(p.id) ?? 0,
    candidates: candsByPiece.get(p.id) ?? 0,
  }));

  // Lifetime runs = distinct run_id in pipeline_log (a 'run' is one day's
  // pipeline attempt — even if it failed before publishing).
  const runsRes = await db
    .prepare('SELECT COUNT(DISTINCT run_id) as n FROM pipeline_log')
    .first<{ n: number }>();
  lifetimeRuns = runsRes?.n ?? 0;

  // Avg revisions across all pieces with audit history.
  if (allPieces.length > 0) {
    const totalRounds = allPieces.reduce((sum, p) => sum + (p.rounds || 0), 0);
    const piecesWithRounds = allPieces.filter((p) => p.rounds > 0).length;
    avgRevisionsLifetime = piecesWithRounds > 0 ? Math.round((totalRounds / piecesWithRounds) * 10) / 10 : null;
  }

  // Pipeline history — terminal step per PIECE (not per day) for the
  // last 14 runs. At multi-per-day cadence a calendar day has multiple
  // pipeline attempts, and grouping by run_id=date hides per-piece run
  // quality (one piece could fail out of two and the day-aggregate view
  // would show only the latest terminal step). Group by piece_id post-
  // migration-0018, join daily_pieces for the headline. Orphan piece_ids
  // (scanner-skipped / error before publish) still surface with a null
  // headline so "stalled" runs are visible. Legacy rows with null
  // piece_id fall through the OR branch so they still render, keyed by
  // run_id alone.
  const histRes = await db
    .prepare(
      `SELECT pl.piece_id, pl.run_id, pl.step, pl.status, pl.data, pl.created_at,
              dp.headline, dp.date AS piece_date
       FROM pipeline_log pl
       LEFT JOIN daily_pieces dp ON dp.id = pl.piece_id
       WHERE pl.id IN (
         SELECT id FROM pipeline_log p1
         WHERE created_at = (
           SELECT MAX(created_at) FROM pipeline_log p2
           WHERE (p2.piece_id IS NOT NULL AND p2.piece_id = p1.piece_id)
              OR (p2.piece_id IS NULL AND p1.piece_id IS NULL AND p2.run_id = p1.run_id)
         )
       )
       ORDER BY pl.created_at DESC LIMIT 14`,
    )
    .all<{ piece_id: string | null; run_id: string; step: string; status: string; data: string | null; created_at: number; headline: string | null; piece_date: string | null }>();
  pipelineHistory = histRes.results.map((r) => ({
    runId: r.run_id,
    pieceId: r.piece_id,
    date: r.piece_date ?? r.run_id,
    headline: r.headline,
    finalStep: r.step,
    finalStatus: r.status,
    data: r.data ? safeJson(r.data) : {},
    tMs: r.created_at,
  }));

  // Engagement per daily piece. Aggregate by piece_id (migration 0017)
  // so two pieces sharing a date at multi-per-day get their own rows.
  // Join daily_pieces to pull the canonical piece date for sort + deep
  // link; lesson_id is carried for display compat with pre-0017 rows
  // (where it held piece_date).
  const engagementRes = await db
    .prepare(
      `SELECT e.piece_id,
              MAX(e.lesson_id) AS lesson_id,
              dp.date AS piece_date,
              SUM(e.views) AS views,
              SUM(e.completions) AS completions,
              SUM(e.audio_plays) AS audio_plays,
              MAX(e.drop_off_beat) AS top_drop_off,
              MAX(e.date) AS last_active
       FROM engagement e
       LEFT JOIN daily_pieces dp ON dp.id = e.piece_id
       WHERE e.course_id = 'daily'
       GROUP BY e.piece_id
       ORDER BY dp.published_at DESC, MAX(e.date) DESC
       LIMIT 30`,
    )
    .all<EngagementRow>();
  engagement = engagementRes.results;

  // Self-improvement loop counters. Moved from /dashboard/ in Task 4 —
  // reader-facing dashboard describes how Zeemish works; operator-facing
  // admin describes how much memory has accumulated. Shared helper at
  // src/lib/learnings.ts.
  learningCounts = await getLearningCounts(db);
} catch { /* D1 may be empty in dev */ }

function safeJson(input: string): any {
  try { return JSON.parse(input); } catch { return {}; }
}

function shortDate(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
}

// Group All Pieces by month ("April 2026" buckets) for the collapsible
// admin list (Area 3 sub-task 3.4). Preserves the incoming sort order
// (date DESC, published_at DESC) inside each bucket. At current volume
// this is cosmetic; at 365+ pieces it stops the list being a 500-row
// scroll wall. Library does flat month-grouping (no collapse); admin
// collapses to keep the rest of the control-room scannable. Kept
// inline rather than extracted — library's item shape and collapse
// behaviour differ enough that a shared component would need
// render-prop gymnastics for no meaningful reuse.
const MONTH_NAMES = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];
type AdminPiece = typeof allPieces[number];
const pieceMonthGroups: { label: string; pieces: AdminPiece[] }[] = [];
for (const piece of allPieces) {
  const [year, monthStr] = piece.date.split('-');
  const label = `${MONTH_NAMES[parseInt(monthStr, 10) - 1]} ${year}`;
  const last = pieceMonthGroups[pieceMonthGroups.length - 1];
  if (last && last.label === label) {
    last.pieces.push(piece);
  } else {
    pieceMonthGroups.push({ label, pieces: [piece] });
  }
}
---

<BaseLayout title="Admin — Zeemish">

  <div class="pt-6 pb-10 flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-zee-gold mb-2">
        The control room
      </p>
      <h1 class="text-3xl md:text-4xl font-bold mb-3 leading-tight tracking-tight">Admin</h1>
      <p class="text-lg text-zee-muted">Trigger runs, watch the pipeline, review escalations.</p>
    </div>
    <div class="flex flex-col items-end gap-1 mt-2 text-sm whitespace-nowrap">
      <a href="/dashboard/admin/settings/" class="text-zee-muted hover:text-zee-primary">Settings →</a>
      <a href="/dashboard/admin/zita/" class="text-zee-muted hover:text-zee-primary">Zita activity →</a>
      <a href="/dashboard/" class="text-zee-muted hover:text-zee-primary">← Public dashboard</a>
    </div>
  </div>

  <!-- Today's run -->
  <section class="mb-10">
    <div class="flex items-center justify-between gap-4 mb-4">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted">Today's run</h2>
      <button
        id="daily-trigger-btn"
        class="px-4 py-2 bg-zee-primary text-white rounded-lg text-sm font-medium hover:opacity-90 transition-opacity"
      >
        Trigger daily piece
      </button>
    </div>
    <span id="trigger-status" class="block text-xs text-zee-muted mb-3 min-h-[1rem]"></span>
    <div class="p-5 rounded-xl border border-zee-border">
      <div id="pipeline-steps" class="space-y-2">
        <p class="text-sm text-zee-muted italic">No pipeline run today. Click trigger to start.</p>
      </div>
    </div>
  </section>

  <!-- System state -->
  <section class="mb-10">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">System state</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="p-4 rounded-xl border border-zee-border text-center">
        <div class="text-2xl font-bold text-zee-primary">{lifetimeRuns}</div>
        <div class="text-sm text-zee-muted">Pipeline runs</div>
        <div class="text-xs text-zee-muted/70 mt-1">lifetime</div>
      </div>
      <div class="p-4 rounded-xl border border-zee-border text-center">
        <div class={`text-2xl font-bold ${openEscalations > 0 ? 'text-zee-gold' : 'text-zee-primary'}`}>{openEscalations}</div>
        <div class="text-sm text-zee-muted">Escalations</div>
        <div class="text-xs text-zee-muted/70 mt-1">unacknowledged</div>
      </div>
      <div class="p-4 rounded-xl border border-zee-border text-center">
        <div class="text-2xl font-bold text-zee-primary">{errorsThisWeek}</div>
        <div class="text-sm text-zee-muted">Errors</div>
        <div class="text-xs text-zee-muted/70 mt-1">last 7 days</div>
      </div>
      <div class="p-4 rounded-xl border border-zee-border text-center">
        <div class="text-2xl font-bold text-zee-primary">{avgRevisionsLifetime ?? '—'}</div>
        <div class="text-sm text-zee-muted">Avg revisions</div>
        <div class="text-xs text-zee-muted/70 mt-1">per piece</div>
      </div>
    </div>
  </section>

  <!-- Learning loop — Producer + self-reflection counters. Moved from
       /dashboard/ in Task 4; reader sees the mechanism on per-piece
       drawers, admin sees accumulated counts here. -->
  {learningCounts.total > 0 && (
    <section class="mb-10">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">Learning loop</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <div class="p-4 rounded-xl border border-zee-border text-center">
          <div class="text-2xl font-bold text-zee-primary tabular-nums">{learningCounts.producer}</div>
          <div class="text-sm text-zee-muted">Producer patterns</div>
        </div>
        <div class="p-4 rounded-xl border border-zee-border text-center">
          <div class="text-2xl font-bold text-zee-primary tabular-nums">{learningCounts.selfReflection}</div>
          <div class="text-sm text-zee-muted">Self-reflections</div>
        </div>
        <div class="p-4 rounded-xl border border-zee-border text-center col-span-2 md:col-span-1">
          <div class="text-2xl font-bold text-zee-primary tabular-nums">{learningCounts.total}</div>
          <div class="text-sm text-zee-muted">Total observations</div>
        </div>
      </div>
    </section>
  )}

  <!-- Observer events -->
  <section class="mb-10">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">
      Observer events
      {observerEvents.filter((e) => !e.acknowledged_at).length > 0 && (
        <span class="text-zee-primary normal-case tracking-normal ml-1">
          ({observerEvents.filter((e) => !e.acknowledged_at).length} new)
        </span>
      )}
    </h2>
    {observerEvents.length === 0 ? (
      <p class="text-zee-muted italic text-sm">No events yet.</p>
    ) : (
      <>
        {/* Severity filter chips — 3 severities confirmed from the
            agents/observer.ts writer enum (info/warn/escalation). When
            something breaks at 2am UTC the operator opens admin and
            wants "what broke" — warn + escalation is that signal. Info
            is noise when triaging; it stays visible under "All".
            Client-side filter (no URL state) — admin is a polling
            surface, filter state is ephemerally session-local. */}
        <nav class="mb-4" aria-label="Filter events by severity">
          <ul class="flex flex-wrap gap-2">
            <li>
              <button
                type="button"
                data-severity-chip="all"
                class="severity-chip inline-flex items-center gap-1.5 min-h-[44px] px-4 py-2 rounded-full text-sm font-medium border transition-colors bg-zee-primary text-white border-zee-primary"
                aria-pressed="true"
              >
                All<span class="opacity-80">{observerEvents.length}</span>
              </button>
            </li>
            <li>
              <button
                type="button"
                data-severity-chip="warn"
                class="severity-chip inline-flex items-center gap-1.5 min-h-[44px] px-4 py-2 rounded-full text-sm font-medium border transition-colors bg-transparent text-zee-text border-zee-border/80 hover:border-zee-primary/50 hover:text-zee-primary"
                aria-pressed="false"
              >
                Warn<span class="text-zee-muted">{observerWarnCount}</span>
              </button>
            </li>
            <li>
              <button
                type="button"
                data-severity-chip="escalation"
                class="severity-chip inline-flex items-center gap-1.5 min-h-[44px] px-4 py-2 rounded-full text-sm font-medium border transition-colors bg-transparent text-zee-text border-zee-border/80 hover:border-zee-primary/50 hover:text-zee-primary"
                aria-pressed="false"
              >
                Escalation<span class="text-zee-muted">{observerEscalationCount}</span>
              </button>
            </li>
          </ul>
        </nav>
        <p
          id="severity-empty-state"
          class="text-zee-muted italic text-sm py-6 hidden"
        >
          No events match this filter.
        </p>
      <div class="space-y-3" id="observer-feed">
        {observerEvents.map((event) => (
          <div
            data-event-id={event.id}
            data-severity={event.severity}
            class={`event-card p-4 rounded-xl border ${
              !event.acknowledged_at
                ? event.severity === 'escalation' ? 'border-zee-gold/40 bg-zee-gold/5' :
                  event.severity === 'warn' ? 'border-zee-muted/30 bg-zee-border/20' :
                  'border-zee-primary/20 bg-zee-primary/5'
                : 'border-zee-border'
            }`}
          >
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <span class={`text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded ${
                  event.severity === 'escalation' ? 'bg-zee-gold/15 text-zee-gold' :
                  event.severity === 'warn' ? 'bg-zee-muted/20 text-zee-text' :
                  'bg-zee-primary/10 text-zee-primary'
                }`}>{event.severity}</span>
                <span class="text-xs text-zee-muted tabular-nums">{new Date(event.created_at).toLocaleString()}</span>
              </div>
              {!event.acknowledged_at && (
                <button class="ack-btn text-xs text-zee-primary hover:underline" data-id={event.id}>
                  Acknowledge
                </button>
              )}
            </div>
            <h3 class="font-medium text-sm">{event.title}</h3>
            <p class="text-sm text-zee-muted mt-1 leading-relaxed">{String(event.body).slice(0, 320)}</p>
          </div>
        ))}
      </div>
      </>
    )}
  </section>

  <!-- All pieces -->
  <section class="mb-10">
    <div class="flex items-baseline justify-between gap-4 mb-4">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted">All pieces</h2>
      <span class="text-xs text-zee-muted">{allPieces.length} {allPieces.length === 1 ? 'piece' : 'pieces'}</span>
    </div>
    {allPieces.length > 5 && (
      <div class="mb-4 border-y border-zee-border/60 py-3">
        <label class="sr-only" for="admin-piece-filter">Filter pieces</label>
        <input
          id="admin-piece-filter"
          type="search"
          placeholder="Filter by date or headline…"
          class="w-full bg-transparent border-0 text-sm placeholder:text-zee-muted focus:outline-none focus:ring-2 focus:ring-zee-primary/30 rounded px-1 -mx-1"
          data-piece-filter
        />
      </div>
    )}
    {allPieces.length === 0 ? (
      <p class="text-sm text-zee-muted italic py-4">No pieces published yet.</p>
    ) : (
      <div class="space-y-3" data-piece-list>
        {pieceMonthGroups.map((group, i) => (
          <details class="group month-group" open={i === 0} data-month-group>
            <summary class="flex items-baseline justify-between gap-4 cursor-pointer list-none py-2 border-b border-zee-border/60">
              <span class="text-xs font-semibold uppercase tracking-widest text-zee-muted">{group.label}</span>
              <span class="flex items-center gap-2 text-xs text-zee-muted tabular-nums">
                <span data-month-count>{group.pieces.length} piece{group.pieces.length === 1 ? '' : 's'}</span>
                <span class="text-zee-muted/60 group-open:rotate-90 transition-transform" aria-hidden="true">▸</span>
              </span>
            </summary>
            <ul class="divide-y divide-zee-border/60">
              {group.pieces.map((p) => {
                const tier = auditTier(p.voice_score, p.quality_flag);
                const tierCls = tier === 'polished' ? 'bg-zee-primary' : tier === 'solid' ? 'bg-zee-text' : 'bg-zee-muted';
                return (
                  <li data-piece-row data-piece-search={`${p.date} ${p.headline}`.toLowerCase()}>
                    <a href={adminPieceHref(p.date)} class="flex items-start gap-4 py-3 group/row">
                      <span class={`w-2 h-2 rounded-full ${tierCls} mt-2 shrink-0`} aria-hidden="true"></span>
                      <div class="flex-1 min-w-0">
                        <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5 text-xs text-zee-muted tabular-nums">
                          <span class="text-zee-text font-medium">{shortDate(p.date)}</span>
                          <span class="opacity-40" aria-hidden="true">·</span>
                          <span>{auditTierLabel(tier)}</span>
                          {p.voice_score != null && (
                            <>
                              <span class="opacity-40" aria-hidden="true">·</span>
                              <span>{p.voice_score}/100</span>
                            </>
                          )}
                          {p.rounds > 0 && (
                            <>
                              <span class="opacity-40" aria-hidden="true">·</span>
                              <span>{p.rounds}r</span>
                            </>
                          )}
                          {p.candidates > 0 && (
                            <>
                              <span class="opacity-40" aria-hidden="true">·</span>
                              <span>{p.candidates}c</span>
                            </>
                          )}
                          {p.quality_flag === 'low' && (
                            <>
                              <span class="opacity-40" aria-hidden="true">·</span>
                              <span class="text-zee-gold">flagged low</span>
                            </>
                          )}
                        </div>
                        <p class="mt-1 text-sm font-medium leading-snug group-hover/row:text-zee-primary transition-colors">
                          {p.headline}
                        </p>
                      </div>
                      <span class="text-zee-muted/60 group-hover/row:text-zee-primary transition-colors shrink-0" aria-hidden="true">→</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </details>
        ))}
      </div>
    )}
    <p class="text-sm text-zee-muted hidden pt-4" data-empty-match>No pieces match that filter.</p>
  </section>

  <!-- Pipeline history — per-piece at multi-per-day cadence, post-0018. -->
  {pipelineHistory.length > 0 && (
    <section class="mb-10">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">Pipeline history (last 14 runs)</h2>
      <ul class="divide-y divide-zee-border/60 text-sm">
        {pipelineHistory.map((r) => {
          // Verdict reads finalStatus, not just step name. Healthy audio runs
          // terminate at `step='audio-publishing', status='done'` — matching
          // on step name alone misread those as "Stalled at audio-publishing".
          const status = r.finalStatus;
          const step = r.finalStep;
          const skipped = step === 'skipped';
          const errored = status === 'failed';
          const running = status === 'running';
          const ok = status === 'done' && !skipped;
          const dotCls = ok ? 'bg-zee-primary' : skipped ? 'bg-zee-muted' : 'bg-zee-gold';
          const stepLabel = pipelineStepLabel(step);
          const verdict = ok ? 'Done'
            : skipped ? 'Skipped'
            : errored ? `Errored at ${stepLabel}`
            : running ? `Running · ${stepLabel}`
            : `Stalled at ${stepLabel}`;
          const score = r.data?.voiceScore != null ? `voice ${r.data.voiceScore}/100` : null;
          const revs = r.data?.revisions != null ? `${r.data.revisions} revision${r.data.revisions === 1 ? '' : 's'}` : null;
          const flag = r.data?.qualityFlag === 'low' ? 'flagged low' : null;
          const label = r.headline ?? '(unpublished run)';
          return (
            <li class="py-3 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 sm:gap-4">
              <div class="flex items-start gap-3 min-w-0">
                <span class={`w-2 h-2 rounded-full ${dotCls} shrink-0 mt-1.5`} aria-hidden="true"></span>
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-baseline gap-x-2">
                    <span class="text-zee-text font-medium tabular-nums">{r.date}</span>
                    <span class="text-zee-muted">— {verdict}</span>
                  </div>
                  <div class="text-xs text-zee-muted truncate" title={label}>{label}</div>
                </div>
              </div>
              <div class="text-xs text-zee-muted tabular-nums flex flex-wrap gap-x-2 sm:justify-end shrink-0">
                {[score, revs, flag].filter(Boolean).map((bit, i, arr) => (
                  <>
                    <span>{bit}</span>
                    {i < arr.length - 1 && <span class="opacity-40">·</span>}
                  </>
                ))}
              </div>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <!-- Engagement -->
  <section class="mb-10">
    <div class="flex items-baseline justify-between gap-4 mb-4">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted">Engagement</h2>
      <span class="text-xs text-zee-muted">{engagement.length} {engagement.length === 1 ? 'piece' : 'pieces'}</span>
    </div>
    {engagement.length === 0 ? (
      <p class="text-sm text-zee-muted italic py-4">No reader activity recorded yet.</p>
    ) : (
      <ul class="divide-y divide-zee-border/60">
        {engagement.map((e) => {
          const completionPct = e.views > 0 ? Math.round((e.completions / e.views) * 100) : 0;
          return (
            <li>
              <a href={adminPieceHref(e.piece_date ?? e.lesson_id, e.piece_id)} class="flex items-start gap-4 py-3 group">
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5 text-xs text-zee-muted tabular-nums">
                    <span class="text-zee-text font-medium">{shortDate(e.piece_date ?? e.lesson_id)}</span>
                    <span class="opacity-40" aria-hidden="true">·</span>
                    <span><span class="text-zee-text">{e.views}</span> {e.views === 1 ? 'view' : 'views'}</span>
                    <span class="opacity-40" aria-hidden="true">·</span>
                    <span><span class="text-zee-text">{e.completions}</span> done ({completionPct}%)</span>
                    <span class="opacity-40" aria-hidden="true">·</span>
                    <span><span class="text-zee-text">{e.audio_plays}</span> audio</span>
                    {e.top_drop_off && (
                      <>
                        <span class="opacity-40" aria-hidden="true">·</span>
                        <span>drop @ <span class="text-zee-text">{e.top_drop_off}</span></span>
                      </>
                    )}
                  </div>
                </div>
                <span class="text-xs text-zee-muted opacity-0 group-hover:opacity-100 transition-opacity mt-0.5">→</span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</BaseLayout>

<script>
  import { pipelineStepLabel } from '../../lib/pipeline-steps';

  const triggerBtn = document.getElementById('daily-trigger-btn') as HTMLButtonElement | null;
  const statusEl = document.getElementById('trigger-status');
  const stepsEl = document.getElementById('pipeline-steps');
  let pollInterval: number | null = null;

  function renderStep(step: any): string {
    const label = pipelineStepLabel(step.step);
    // Tristate icon: terminal-with-success, terminal-with-failure, in-flight.
    const icon = step.status === 'done'
      ? '✓'
      : step.status === 'failed' || step.status === 'error'
        ? '✗'
        : '·';
    const iconCls = step.status === 'done'
      ? 'text-zee-primary'
      : step.status === 'failed' || step.status === 'error'
        ? 'text-zee-gold'
        : 'text-zee-muted animate-pulse';

    let detail = '';
    const d = step.data || {};
    if (d.candidateCount != null) detail = `${d.candidateCount} candidates`;
    if (d.headline) detail = `"${escapeHtml(String(d.headline))}"`;
    if (d.subject) detail += ` · ${escapeHtml(String(d.subject))}`;
    if (d.wordCount) detail = `${d.wordCount} words · ${d.beatCount} beats`;
    if (d.voiceScore != null) {
      detail = `Voice: ${d.voiceScore}/100`;
      if (d.factsPassed != null) detail += ` · Facts: ${d.factsPassed ? '✓' : '✗'}`;
      if (d.structurePassed != null) detail += ` · Structure: ${d.structurePassed ? '✓' : '✗'}`;
    }
    if (d.failedGates) detail = `Failed: ${d.failedGates.join(', ')}`;
    if (d.commitUrl) detail = `<a href="${d.commitUrl}" class="text-zee-primary hover:underline" target="_blank" rel="noopener">View commit</a>`;
    if (d.reason) detail = escapeHtml(String(d.reason));
    if (d.error) detail = escapeHtml(String(d.error));
    if (step.step === 'done' && d.voiceScore) {
      detail = `Voice: ${d.voiceScore}/100 · ${d.revisions} revision${d.revisions !== 1 ? 's' : ''}`;
      if (d.qualityFlag === 'low') {
        detail += ` · <span class="text-zee-gold font-medium">FLAGGED LOW</span>`;
        if (d.failedGates) detail += ` (failed: ${d.failedGates.join(', ')})`;
      }
    }
    if (step.step === 'publishing' && step.status === 'done' && d.qualityFlag === 'low') {
      detail += ` <span class="text-zee-gold font-medium">[low quality]</span>`;
    }

    return `<div class="flex items-start gap-3 py-1.5">
      <span class="${iconCls} font-bold text-base leading-tight w-3 mt-0.5">${icon}</span>
      <div class="flex-1 min-w-0">
        <span class="font-medium text-sm">${escapeHtml(label)}</span>
        ${detail ? `<span class="text-sm text-zee-muted ml-2">${detail}</span>` : ''}
      </div>
    </div>`;
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
    } as Record<string, string>)[c] ?? "&#39;");
  }

  /** Real "is the pipeline still running?" check. The /api/dashboard/pipeline
   *  isRunning flag only checks step name, not status — a row with
   *  step='auditing_r1' status='done' falsely reports running. We re-check
   *  here using both: the LATEST row must have status='running' AND its
   *  step must not be one of the terminal step names. */
  function pipelineIsRunning(steps: any[]): boolean {
    if (steps.length === 0) return false;
    const last = steps[steps.length - 1];
    const terminalSteps = ['done', 'error', 'skipped'];
    if (terminalSteps.includes(last.step)) return false;
    return last.status === 'running';
  }

  function renderGroup(group: { pieceId: string | null; steps: any[] }, headline: { headline: string; published_at: number | null } | undefined, openByDefault: boolean): string {
    const stepsHtml = group.steps.map(renderStep).join('');
    const pieceLabel = headline
      ? escapeHtml(headline.headline)
      : group.pieceId
        ? `<code class="text-xs">${escapeHtml(group.pieceId.slice(0, 8))}…</code>`
        : '<span class="text-zee-muted italic">legacy (pre-piece_id)</span>';
    const publishedDisplay = headline?.published_at
      ? new Date(headline.published_at).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' })
      : '';
    const summary = `
      <summary class="cursor-pointer list-none flex items-center justify-between gap-3 py-2">
        <div class="flex-1 min-w-0">
          <span class="text-sm font-medium leading-tight block truncate">${pieceLabel}</span>
          ${publishedDisplay ? `<span class="text-xs text-zee-muted tabular-nums">published ${publishedDisplay} UTC · ${group.steps.length} steps</span>` : `<span class="text-xs text-zee-muted">${group.steps.length} steps</span>`}
        </div>
        <span class="text-xs text-zee-muted group-open:rotate-90 transition-transform">▸</span>
      </summary>
    `;
    return `<details class="group border-b border-zee-border/40 last:border-b-0" ${openByDefault ? 'open' : ''}>
      ${summary}
      <div class="pb-2 pl-1">${stepsHtml}</div>
    </details>`;
  }

  async function pollPipeline() {
    if (!stepsEl) return;
    try {
      const res = await fetch('/api/dashboard/pipeline');
      if (!res.ok) return;
      const data = await res.json();

      if (data.steps.length === 0) {
        stepsEl.innerHTML = '<p class="text-sm text-zee-muted italic">No pipeline run today. Click trigger to start.</p>';
        return;
      }

      // If groups came back (new API shape, Phase 4+), render one
      // collapsible block per piece_id. Newest open by default,
      // older ones closed for compactness. Falls back to flat-stream
      // render if groups is empty (legacy API or all-null piece_id
      // in response).
      if (Array.isArray(data.groups) && data.groups.length > 0) {
        const newestIdx = data.groups.length - 1;
        stepsEl.innerHTML = data.groups
          .map((g: any, i: number) => renderGroup(g, data.headlines?.[g.pieceId], i === newestIdx))
          .join('');
      } else {
        stepsEl.innerHTML = data.steps.map(renderStep).join('');
      }

      const running = pipelineIsRunning(data.steps);
      if (!running && pollInterval) {
        clearInterval(pollInterval);
        pollInterval = null;
        if (triggerBtn) triggerBtn.disabled = false;
        if (statusEl) statusEl.textContent = '';
      }
    } catch { /* silent — next tick will retry */ }
  }

  triggerBtn?.addEventListener('click', async () => {
    if (!stepsEl || !statusEl || !triggerBtn) return;
    triggerBtn.disabled = true;
    statusEl.textContent = 'Starting pipeline…';
    stepsEl.innerHTML = '<p class="text-sm text-zee-muted">⏳ Starting…</p>';

    try {
      const res = await fetch('/api/agents/trigger', { method: 'POST' });
      if (!res.ok) {
        let detail = res.statusText;
        try {
          const body = await res.json() as { error?: string };
          if (body.error) detail = body.error;
        } catch { /* not JSON */ }
        statusEl.textContent = `Failed: ${res.status} ${detail}`;
        stepsEl.innerHTML = `<p class="text-sm text-zee-gold">Trigger failed — ${res.status} ${detail}</p>`;
        triggerBtn.disabled = false;
        return;
      }

      const body = await res.json() as { runId?: string };
      statusEl.textContent = body.runId ? `Started (run ${body.runId}). Polling…` : 'Started. Polling…';
      pollInterval = window.setInterval(pollPipeline, 5000);
      setTimeout(pollPipeline, 2000);
    } catch (err) {
      const message = err instanceof Error ? err.message : 'Network error';
      statusEl.textContent = `Failed: ${message}`;
      stepsEl.innerHTML = `<p class="text-sm text-zee-gold">Trigger failed — ${message}</p>`;
      triggerBtn.disabled = false;
    }
  });

  pollPipeline();

  // Acknowledge observer events. After ack, fade the card to muted state
  // and remove the button — no page reload required.
  document.querySelectorAll('.ack-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const eventId = (btn as HTMLElement).dataset.id;
      if (!eventId) return;
      try {
        const res = await fetch('/api/dashboard/observer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ eventId }),
        });
        if (!res.ok) throw new Error(`Ack failed: ${res.status}`);
        // Soften the card and remove the button.
        const card = (btn as HTMLElement).closest('[data-event-id]') as HTMLElement | null;
        if (card) card.className = 'event-card p-4 rounded-xl border border-zee-border';
        (btn as HTMLElement).remove();
      } catch (err) {
        (btn as HTMLElement).textContent = 'Failed';
      }
    });
  });

  // Severity filter chips. Click toggles: only cards matching the
  // active severity stay visible; "All" shows everything. Empty-state
  // copy surfaces when a filter returns zero cards. Same classes as
  // the library chip bar for visual consistency.
  const chipActiveClass = ['bg-zee-primary', 'text-white', 'border-zee-primary'];
  const chipIdleClass = ['bg-transparent', 'text-zee-text', 'border-zee-border/80', 'hover:border-zee-primary/50', 'hover:text-zee-primary'];
  const severityChips = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-severity-chip]'));
  const observerCards = Array.from(document.querySelectorAll<HTMLElement>('#observer-feed [data-severity]'));
  const severityEmptyState = document.getElementById('severity-empty-state');
  function applySeverityFilter(active: string) {
    let anyVisible = false;
    for (const card of observerCards) {
      const show = active === 'all' || card.dataset.severity === active;
      card.style.display = show ? '' : 'none';
      if (show) anyVisible = true;
    }
    if (severityEmptyState) {
      severityEmptyState.classList.toggle('hidden', anyVisible || observerCards.length === 0);
    }
    for (const chip of severityChips) {
      const isActive = chip.dataset.severityChip === active;
      chip.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      chip.classList.remove(...chipActiveClass, ...chipIdleClass);
      chip.classList.add(...(isActive ? chipActiveClass : chipIdleClass));
    }
  }
  for (const chip of severityChips) {
    chip.addEventListener('click', () => applySeverityFilter(chip.dataset.severityChip ?? 'all'));
  }

  // Filter the All Pieces list. Month groups auto-expand when any of
  // their pieces match the filter; groups with zero matches hide
  // entirely (not just collapse — matches library's hide-empty-groups
  // pattern). When the filter is cleared, user-expanded groups stay
  // expanded — we don't reset to default open state because fighting
  // the user's explicit expand is annoying.
  const filterInput = document.querySelector<HTMLInputElement>('[data-piece-filter]');
  const pieceRows = Array.from(document.querySelectorAll<HTMLElement>('[data-piece-row]'));
  const monthGroups = Array.from(document.querySelectorAll<HTMLDetailsElement>('[data-month-group]'));
  const emptyNote = document.querySelector<HTMLElement>('[data-empty-match]');
  filterInput?.addEventListener('input', () => {
    const q = filterInput.value.trim().toLowerCase();
    let anyVisible = false;
    for (const row of pieceRows) {
      const haystack = row.dataset.pieceSearch ?? '';
      const match = !q || haystack.includes(q);
      row.style.display = match ? '' : 'none';
      if (match) anyVisible = true;
    }
    for (const group of monthGroups) {
      const rowsInGroup = group.querySelectorAll<HTMLElement>('[data-piece-row]');
      const visibleInGroup = Array.from(rowsInGroup).some((r) => r.style.display !== 'none');
      group.style.display = visibleInGroup ? '' : 'none';
      // Auto-expand a group with a match; leave groups without matches
      // in their prior open state (they'll be hidden anyway).
      if (q && visibleInGroup) group.open = true;
    }
    if (emptyNote) emptyNote.style.display = anyVisible ? 'none' : 'block';
  });
</script>
