---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';

const url = new URL(Astro.request.url);
const isUpgrade = url.searchParams.get('upgrade') === '1';
const redirect = url.searchParams.get('redirect') ?? '/account/';

const eyebrow = isUpgrade ? 'Save your progress' : 'Sign in';
const title = isUpgrade ? 'Save your progress' : 'Log in';
const subtitle = isUpgrade
  ? "Enter your email. We'll send you a link — click it and your reading progress is saved across devices."
  : "Enter your email. We'll send you a login link.";
---

<BaseLayout title={isUpgrade ? 'Save your progress — Zeemish' : 'Log in — Zeemish'}>
  <div class="max-w-md mx-auto pt-6 pb-16">
    <p class="text-xs font-semibold uppercase tracking-widest text-zee-gold mb-2">
      {eyebrow}
    </p>
    <h1 class="text-3xl md:text-4xl font-bold mb-3 leading-tight tracking-tight">{title}</h1>
    <p class="text-lg text-zee-muted mb-8 leading-relaxed">{subtitle}</p>

    <div id="error-msg" class="hidden mb-4 p-3 rounded-lg border border-zee-gold/30 bg-zee-gold/5 text-sm text-zee-text"></div>
    <div id="success-msg" class="hidden mb-4 p-3 rounded-lg border border-zee-primary/30 bg-zee-primary/5 text-sm text-zee-text"></div>

    <form id="magic-form" class="space-y-4">
      <div>
        <label for="magic-email" class="block text-xs font-semibold uppercase tracking-widest text-zee-muted mb-2">Email</label>
        <input
          type="email"
          id="magic-email"
          name="email"
          required
          class="w-full px-3 py-2.5 rounded-lg border border-zee-border bg-white text-zee-text placeholder:text-zee-muted/60 focus:outline-none focus:ring-2 focus:ring-zee-primary/30 focus:border-zee-primary"
          placeholder="you@example.com"
        />
      </div>
      <button
        type="submit"
        id="magic-btn"
        class="w-full px-4 py-2.5 bg-zee-primary text-white rounded-lg font-medium hover:opacity-90 transition-opacity"
      >
        Send login link
      </button>
    </form>

    {!isUpgrade && (
      <p class="mt-8 text-sm text-zee-muted text-center">
        No account? Just <a href="/" class="text-zee-primary hover:underline">start reading</a> — progress saves automatically once you do.
      </p>
    )}
  </div>
</BaseLayout>

<script define:vars={{ isUpgrade, redirect }}>
  const form = document.getElementById('magic-form');
  const errorMsg = document.getElementById('error-msg');
  const successMsg = document.getElementById('success-msg');
  const btn = document.getElementById('magic-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg?.classList.add('hidden');
    successMsg?.classList.add('hidden');

    const email = document.getElementById('magic-email').value;

    btn.disabled = true;
    btn.textContent = 'Sending…';

    try {
      const res = await fetch('/api/auth/magic-link', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      const data = await res.json();

      if (!res.ok) {
        errorMsg.textContent = data.error || 'Something went wrong';
        errorMsg?.classList.remove('hidden');
      } else {
        successMsg.textContent = 'Check your email — we sent you a login link.';
        successMsg?.classList.remove('hidden');
        form?.classList.add('hidden');
      }
    } catch {
      errorMsg.textContent = 'Network error. Please try again.';
      errorMsg?.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send login link';
    }
  });
</script>
