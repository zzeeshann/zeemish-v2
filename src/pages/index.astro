---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatTime, formatDate } from '../lib/format';

const dailyPieces = await getCollection('dailyPieces');
const sorted = [...dailyPieces].sort((a, b) => b.data.date.localeCompare(a.data.date));
const todaysPiece = sorted[0];
// "From the library" is the archive strip — filter low-quality pieces out
// same as /library/. The "Today" slot above keeps showing today's piece
// even if it's low (the day shouldn't be blank), and /daily/[date]/
// surfaces a banner on that page.
const recentPieces = sorted.slice(1, 6).filter((p) => p.data.qualityFlag !== 'low');

// Long-form date for the eyebrow on today's hero
let heroDate = '';
if (todaysPiece) {
  const d = new Date(todaysPiece.data.date);
  if (!Number.isNaN(d.getTime())) {
    heroDate = d.toLocaleDateString('en-GB', {
      weekday: 'long',
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    });
  }
}
---

<BaseLayout title="Zeemish" description="Educate yourself for humble decisions.">

  {todaysPiece ? (
    <>
      <!-- Today's piece — hero -->
      <section class="pt-6 pb-12 md:pt-10 md:pb-16">
        <p class="text-xs font-semibold uppercase tracking-widest text-zee-gold mb-2">
          Today <span class="text-zee-muted/60 font-normal normal-case tracking-normal ml-2">· {heroDate}</span>
        </p>

        <a href={`/daily/${todaysPiece.data.date}/`} class="block group mt-4">
          <h1 class="text-3xl md:text-5xl font-bold leading-[1.08] tracking-tight group-hover:text-zee-primary transition-colors">
            {todaysPiece.data.title}
          </h1>
          <p class="text-lg md:text-xl text-zee-muted mt-5 max-w-2xl leading-relaxed">
            {todaysPiece.data.description}
          </p>
          <div class="mt-6 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-zee-muted">
            <span>{formatTime(todaysPiece.data.estimatedTime)}</span>
            {todaysPiece.data.beatCount && (
              <>
                <span class="opacity-40" aria-hidden="true">·</span>
                <span>{todaysPiece.data.beatCount} {todaysPiece.data.beatCount === 1 ? 'beat' : 'beats'}</span>
              </>
            )}
            {todaysPiece.data.underlyingSubject && (
              <>
                <span class="opacity-40" aria-hidden="true">·</span>
                <span>{todaysPiece.data.underlyingSubject}</span>
              </>
            )}
          </div>
          <div class="mt-7 inline-flex items-center gap-2 text-sm font-medium text-zee-primary group-hover:gap-3 transition-all">
            Read today's piece
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </a>
      </section>

      <!-- How this was made — transparency strip -->
      <section class="py-6 border-y border-zee-border/60">
        <p class="text-xs text-zee-muted leading-relaxed">
          <span class="font-medium text-zee-text">Made by 13 agents.</span>
          Today's piece moved through
          <span class="text-zee-text">Scanner → Curator → Drafter → Voice · Facts · Structure → Publisher</span>
          before going live.
          <a href="/dashboard/" class="text-zee-primary hover:underline ml-1 whitespace-nowrap">See the pipeline →</a>
        </p>
      </section>
    </>
  ) : (
    <section class="py-20 md:py-28">
      <p class="text-xs font-semibold uppercase tracking-widest text-zee-gold mb-4">No piece today</p>
      <h1 class="text-3xl md:text-5xl font-bold leading-[1.08] tracking-tight mb-6">
        Educate yourself for humble decisions.
      </h1>
      <p class="text-lg md:text-xl text-zee-muted max-w-2xl leading-relaxed mb-8">
        Every morning at 2am UTC, one piece. Today's news, explained.
        The machinery behind the headlines.
      </p>
      <a href="/library/" class="inline-flex items-center gap-2 text-sm font-medium text-zee-primary hover:gap-3 transition-all">
        Browse the library
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </section>
  )}

  <!-- Recent pieces -->
  {recentPieces.length > 0 && (
    <section class="py-12 md:py-16">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted">Recent</h2>
        <a href="/library/" class="text-sm text-zee-primary hover:underline">All pieces →</a>
      </div>
      <ul class="divide-y divide-zee-border/60">
        {recentPieces.map((piece) => (
          <li>
            <a
              href={`/daily/${piece.data.date}/`}
              class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 sm:gap-6 py-4 group"
            >
              <div class="flex-1 min-w-0">
                <p class="font-medium text-base leading-snug group-hover:text-zee-primary transition-colors">
                  {piece.data.title}
                </p>
                {piece.data.underlyingSubject && (
                  <p class="text-xs text-zee-muted mt-1">{piece.data.underlyingSubject}</p>
                )}
              </div>
              <span class="text-xs text-zee-muted whitespace-nowrap font-variant-tabular">
                {formatDate(piece.data.date)}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
