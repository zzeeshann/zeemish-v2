---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const dailyPieces = await getCollection('dailyPieces');
const sorted = [...dailyPieces].sort((a, b) => b.data.date.localeCompare(a.data.date));
const todaysPiece = sorted[0];
const recentPieces = sorted.slice(1, 6);
---

<BaseLayout title="Zeemish" description="Educate yourself for humble decisions.">

  <!-- Today's piece -->
  {todaysPiece ? (
    <section class="py-10 md:py-16">
      <span class="text-xs font-medium text-zee-gold uppercase tracking-wide">Today</span>
      <a href={`/daily/${todaysPiece.data.date}/`} class="block mt-3 group">
        <h1 class="text-3xl md:text-4xl font-bold leading-tight group-hover:text-zee-primary transition-colors">
          {todaysPiece.data.title}
        </h1>
        <p class="text-lg text-zee-muted mt-3 max-w-xl leading-relaxed">{todaysPiece.data.description}</p>
        <div class="flex items-center gap-3 mt-4 text-sm text-zee-muted">
          <span>{todaysPiece.data.estimatedTime}</span>
          {todaysPiece.data.underlyingSubject && (
            <>
              <span>&middot;</span>
              <span>{todaysPiece.data.underlyingSubject}</span>
            </>
          )}
        </div>
      </a>
      <div class="mt-8 h-px w-16 bg-zee-gold"></div>
    </section>
  ) : (
    <section class="py-16 md:py-24">
      <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-4">
        Educate yourself for humble decisions.
      </h1>
      <p class="text-lg text-zee-muted max-w-md leading-relaxed">
        Every morning, one piece. Today's news, explained. The machinery behind the headlines.
      </p>
      <div class="mt-12 h-px w-16 bg-zee-gold"></div>
    </section>
  )}

  <!-- From the library -->
  {recentPieces.length > 0 && (
    <section class="mb-12">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-medium text-zee-muted uppercase tracking-wide">From the library</h2>
        <a href="/library/" class="text-sm text-zee-primary hover:underline">All pieces</a>
      </div>
      <div class="space-y-2">
        {recentPieces.map((piece) => (
          <a
            href={`/daily/${piece.data.date}/`}
            class="flex items-baseline justify-between px-4 py-3 -mx-4 rounded-lg hover:bg-zee-border/50 transition-colors group"
          >
            <span class="font-medium group-hover:text-zee-primary transition-colors text-sm flex-1">
              {piece.data.title}
            </span>
            <span class="text-xs text-zee-muted ml-4 shrink-0">{piece.data.date}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Protocol -->
  <section class="py-8 text-center">
    <p class="text-sm text-zee-muted italic">Educate yourself for humble decisions.</p>
  </section>
</BaseLayout>
