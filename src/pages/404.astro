---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found — Zeemish" description="The page you're looking for doesn't exist on Zeemish.">
  <div class="pt-12 pb-16">
    <p class="text-xs font-semibold uppercase tracking-widest text-zee-gold mb-3">
      Not found
    </p>

    <h1 class="text-3xl md:text-5xl font-bold mb-5 leading-[1.08] tracking-tight">
      You've reached a dead end.
    </h1>

    <p class="text-lg md:text-xl text-zee-muted max-w-2xl leading-relaxed mb-8">
      The page you're looking for doesn't exist on Zeemish. Try one of these:
    </p>

    <ul class="divide-y divide-zee-border/60">
      <li>
        <a href="/" class="flex items-baseline justify-between py-3 group">
          <span class="font-medium group-hover:text-zee-primary transition-colors">Today's piece</span>
          <span class="text-sm text-zee-primary group-hover:gap-3 transition-all">→</span>
        </a>
      </li>
      <li>
        <a href="/library/" class="flex items-baseline justify-between py-3 group">
          <span class="font-medium group-hover:text-zee-primary transition-colors">The library</span>
          <span class="text-sm text-zee-primary group-hover:gap-3 transition-all">→</span>
        </a>
      </li>
      <li>
        <a href="/dashboard/" class="flex items-baseline justify-between py-3 group">
          <span class="font-medium group-hover:text-zee-primary transition-colors">The dashboard</span>
          <span class="text-sm text-zee-primary group-hover:gap-3 transition-all">→</span>
        </a>
      </li>
    </ul>
  </div>
</BaseLayout>
