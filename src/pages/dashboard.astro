---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getUser } from '../lib/db';

// Auth check — admin only (requires email account)
const db = Astro.locals.runtime.env.DB;
const userId = Astro.locals.userId;
const user = userId ? await getUser(db, userId) : null;
if (!user?.email) {
  return Astro.redirect('/login/?redirect=/dashboard/');
}

// Fetch data from agents worker + D1
const AGENTS_URL = 'https://zeemish-agents.zzeeshann.workers.dev';
const ADMIN_SECRET = (Astro.locals.runtime.env as Record<string, string>).AGENTS_ADMIN_SECRET ?? '';
const authHeader = { 'Authorization': `Bearer ${ADMIN_SECRET}` };

let directorStatus = { status: 'unknown', currentTask: null, lastLesson: null, lastDailyPiece: null, error: null };
let digest = { published: 0, escalated: 0, errors: 0, events: [] as any[] };

try {
  const [statusRes, digestRes] = await Promise.all([
    fetch(`${AGENTS_URL}/status`, { headers: authHeader }),
    fetch(`${AGENTS_URL}/digest`, { headers: authHeader }),
  ]);
  if (statusRes.ok) directorStatus = await statusRes.json();
  if (digestRes.ok) digest = await digestRes.json();
} catch { /* agents worker may be unavailable */ }

// Recent daily pieces from D1
let recentPieces: any[] = [];
try {
  const result = await db.prepare(
    'SELECT * FROM daily_pieces ORDER BY date DESC LIMIT 7'
  ).all();
  recentPieces = result.results;
} catch { /* table may not have data yet */ }

// Recent audit results
let recentAudits: any[] = [];
try {
  const result = await db.prepare(
    'SELECT * FROM audit_results ORDER BY created_at DESC LIMIT 20'
  ).all();
  recentAudits = result.results;
} catch { /* */ }

// Engagement data
let engagementData: any[] = [];
try {
  const result = await db.prepare(
    'SELECT * FROM engagement ORDER BY date DESC LIMIT 14'
  ).all();
  engagementData = result.results;
} catch { /* */ }
---

<BaseLayout title="Dashboard — Zeemish">
  <h1 class="text-2xl md:text-3xl font-bold mb-2">Dashboard</h1>
  <p class="text-zee-muted text-sm mb-8">The control room. What the agents are doing.</p>

  <!-- Director Status -->
  <section class="mb-10">
    <h2 class="text-sm font-medium text-zee-muted uppercase tracking-wide mb-4">Director</h2>
    <div class="p-5 rounded-xl border border-zee-border">
      <div class="flex items-center gap-3 mb-3">
        <span class={`w-2.5 h-2.5 rounded-full ${
          directorStatus.status === 'idle' ? 'bg-green-500' :
          directorStatus.status === 'error' ? 'bg-red-500' :
          'bg-yellow-500 animate-pulse'
        }`}></span>
        <span class="font-medium capitalize">{directorStatus.status}</span>
      </div>
      {directorStatus.currentTask && (
        <p class="text-sm text-zee-muted">Working on: {directorStatus.currentTask}</p>
      )}
      {(directorStatus.lastDailyPiece as any) && (
        <p class="text-sm text-zee-muted">
          Last daily piece: {(directorStatus.lastDailyPiece as any).title} ({(directorStatus.lastDailyPiece as any).date})
        </p>
      )}
      {directorStatus.error && (
        <p class="text-sm text-red-600 mt-2">{String(directorStatus.error).slice(0, 200)}</p>
      )}
    </div>
  </section>

  <!-- 24hr Summary -->
  <section class="mb-10">
    <h2 class="text-sm font-medium text-zee-muted uppercase tracking-wide mb-4">Last 24 Hours</h2>
    <div class="grid grid-cols-3 gap-4">
      <div class="p-4 rounded-xl border border-zee-border text-center">
        <div class="text-2xl font-bold text-zee-primary">{digest.published}</div>
        <div class="text-sm text-zee-muted">Published</div>
      </div>
      <div class="p-4 rounded-xl border border-zee-border text-center">
        <div class="text-2xl font-bold text-yellow-600">{digest.escalated}</div>
        <div class="text-sm text-zee-muted">Escalated</div>
      </div>
      <div class="p-4 rounded-xl border border-zee-border text-center">
        <div class="text-2xl font-bold text-red-600">{digest.errors}</div>
        <div class="text-sm text-zee-muted">Errors</div>
      </div>
    </div>
  </section>

  <!-- Recent Pieces -->
  <section class="mb-10">
    <h2 class="text-sm font-medium text-zee-muted uppercase tracking-wide mb-4">Recent Pieces (7 days)</h2>
    {recentPieces.length === 0 ? (
      <p class="text-zee-muted italic text-sm">No pieces published yet.</p>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-zee-border text-left text-zee-muted">
              <th class="pb-2 pr-4">Date</th>
              <th class="pb-2 pr-4">Title</th>
              <th class="pb-2 pr-4">Subject</th>
              <th class="pb-2">Words</th>
            </tr>
          </thead>
          <tbody>
            {recentPieces.map((piece: any) => (
              <tr class="border-b border-zee-border/50">
                <td class="py-2 pr-4 text-zee-muted">{piece.date}</td>
                <td class="py-2 pr-4 font-medium">{piece.headline}</td>
                <td class="py-2 pr-4 text-zee-muted">{piece.underlying_subject}</td>
                <td class="py-2 text-zee-muted">{piece.word_count}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>

  <!-- Observer Events -->
  <section class="mb-10">
    <h2 class="text-sm font-medium text-zee-muted uppercase tracking-wide mb-4">Observer Events</h2>
    {digest.events.length === 0 ? (
      <p class="text-zee-muted italic text-sm">No events yet.</p>
    ) : (
      <div class="space-y-3">
        {digest.events.map((event: any) => (
          <div class={`p-4 rounded-xl border ${
            event.severity === 'info' ? 'border-zee-primary/20 bg-zee-primary/5' :
            event.severity === 'escalation' ? 'border-yellow-500/20 bg-yellow-50' :
            'border-red-500/20 bg-red-50'
          }`}>
            <div class="flex items-center gap-2 mb-1">
              <span class={`text-xs font-medium uppercase px-2 py-0.5 rounded ${
                event.severity === 'info' ? 'bg-zee-primary/10 text-zee-primary' :
                event.severity === 'escalation' ? 'bg-yellow-100 text-yellow-700' :
                'bg-red-100 text-red-700'
              }`}>{event.severity}</span>
              <span class="text-xs text-zee-muted">{new Date(event.created_at).toLocaleString()}</span>
            </div>
            <h3 class="font-medium text-sm">{event.title}</h3>
            <p class="text-sm text-zee-muted mt-1">{String(event.body).slice(0, 200)}</p>
          </div>
        ))}
      </div>
    )}
  </section>

  <!-- Engagement -->
  <section class="mb-10">
    <h2 class="text-sm font-medium text-zee-muted uppercase tracking-wide mb-4">Engagement (last 14 days)</h2>
    {engagementData.length === 0 ? (
      <p class="text-zee-muted italic text-sm">No engagement data yet. Readers need to visit lessons first.</p>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-zee-border text-left text-zee-muted">
              <th class="pb-2 pr-4">Date</th>
              <th class="pb-2 pr-4">Piece</th>
              <th class="pb-2 pr-4">Views</th>
              <th class="pb-2 pr-4">Completions</th>
              <th class="pb-2">Drop-off</th>
            </tr>
          </thead>
          <tbody>
            {engagementData.map((row: any) => (
              <tr class="border-b border-zee-border/50">
                <td class="py-2 pr-4 text-zee-muted">{row.date}</td>
                <td class="py-2 pr-4">{row.lesson_id}</td>
                <td class="py-2 pr-4">{row.views}</td>
                <td class="py-2 pr-4">{row.completions}</td>
                <td class="py-2 text-zee-muted">{row.drop_off_beat ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>

  <!-- Manual Trigger -->
  <section class="pt-8 border-t border-zee-border">
    <h2 class="text-sm font-medium text-zee-muted uppercase tracking-wide mb-4">Manual Trigger</h2>
    <div class="flex flex-wrap gap-3">
      <button id="daily-trigger-btn"
        class="px-5 py-3 bg-zee-primary text-white rounded-lg text-sm font-medium hover:opacity-90 transition-opacity">
        Trigger Daily Piece
      </button>
      <span id="trigger-status" class="text-sm text-zee-muted self-center"></span>
    </div>
  </section>
</BaseLayout>

<script>
  const btn = document.getElementById('daily-trigger-btn') as HTMLButtonElement;
  const statusEl = document.getElementById('trigger-status');

  btn?.addEventListener('click', async () => {
    btn.disabled = true;
    statusEl!.textContent = 'Running pipeline (60-120s)...';

    try {
      const res = await fetch('/api/agents/trigger', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: 'daily' }),
      });
      const data = await res.json();

      if (data.status === 'success') {
        statusEl!.textContent = `Published: ${data.headline}`;
      } else if (data.status === 'skipped') {
        statusEl!.textContent = 'Skipped — no teachable stories today';
      } else {
        statusEl!.textContent = `Error: ${data.error?.slice(0, 100) ?? 'Unknown'}`;
      }
    } catch {
      statusEl!.textContent = 'Network error';
    } finally {
      btn.disabled = false;
    }
  });
</script>
