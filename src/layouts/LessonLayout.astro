---
import BaseLayout from './BaseLayout.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
import { auditTier, auditTierLabel } from '../lib/audit-tier';
import '../styles/beats.css';
import '../styles/zita.css';

interface Props {
  title: string;
  estimatedTime: string;
  audioBeats?: Record<string, string>;
  /** Legacy single-clip audio path. Pre-Area-4-style pieces; current
   *  pipeline emits per-beat clips into audioBeats instead. */
  audioSrc?: string;
  beatCount?: number;
  subject?: string;
  date?: string;
  /** daily_pieces.id (UUID) — optional. When present, scopes Zita
   *  observer events (truncation, Claude errors, handler errors) to the
   *  piece via piece_id. Migration 0020 added the column (2026-04-22);
   *  site-worker threading completes the loop in sub-task 3.2. */
  pieceId?: string;
  /** Unix-ms timestamp from MDX frontmatter `publishedAt`. Threads down
   *  to BaseLayout for the JSON-LD Article schema's datePublished /
   *  dateModified fields. */
  publishedAt: number;
  voiceScore?: number;
  qualityFlag?: 'low';
  /** Optional one-line description for social-share meta. */
  description?: string;
  /** Optional interactive metadata for the last-beat prompt (sub-task 4.6).
   *  When present, <lesson-shell> reads it from the embedded JSON
   *  script tag and surfaces a link to /interactives/<slug>/ on the
   *  last beat, above the Finish button. */
  interactive?: {
    slug: string;
    title: string;
    questionCount: number | null;
  } | null;
}

const { title, estimatedTime, audioBeats, audioSrc, beatCount, subject, date, pieceId, publishedAt, voiceScore, qualityFlag, description, interactive } = Astro.props;

// Pick a representative audio URL for the JSON-LD AudioObject (v1 emits
// one per Article — array-per-beat is deferred). Prefer legacy
// audioSrc when set; else the "hook" beat (the standard opening beat
// across every piece in this codebase); else the first beat in
// iteration order. Any beat works for SEO purposes — Google just needs
// to see audio is present.
let canonicalAudioUrl: string | undefined;
if (audioSrc) {
  canonicalAudioUrl = audioSrc;
} else if (audioBeats) {
  canonicalAudioUrl = audioBeats['hook'] ?? Object.values(audioBeats)[0];
}
const timeDisplay = String(estimatedTime).includes('min') ? estimatedTime : `${estimatedTime} min`;
// Tier is a quiet, consistent signal shown in the metadata line — same
// visual weight as the date. Every piece shows its tier (not just rough
// ones) so the word doesn't become a warning by absence.
const tier = auditTier(voiceScore, qualityFlag);
const tierLabel = auditTierLabel(tier);

let dateDisplay = '';
if (date) {
  const d = new Date(date);
  if (!Number.isNaN(d.getTime())) {
    dateDisplay = d.toLocaleDateString('en-GB', {
      weekday: 'long',
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    });
  }
}
---

<BaseLayout
  title={`${title} — Zeemish`}
  description={description}
  ogType="article"
  article={{ publishedAt, audioUrl: canonicalAudioUrl }}
>
  <nav class="text-sm text-zee-muted mb-6" aria-label="Breadcrumb">
    <a href="/daily/" class="hover:text-zee-primary transition-colors">Daily</a>
    <span class="mx-2 opacity-50">/</span>
    <span class="text-zee-text">Today</span>
  </nav>

  {dateDisplay && (
    <p class="text-xs font-semibold uppercase tracking-widest text-zee-gold mb-3">{dateDisplay}</p>
  )}

  <h1 class="text-3xl md:text-4xl font-bold mb-4 leading-[1.15] tracking-tight">{title}</h1>

  <p class="text-sm text-zee-muted mb-8 flex flex-wrap items-center gap-x-2 gap-y-1">
    <span>{timeDisplay}</span>
    {subject && (
      <>
        <span class="opacity-40" aria-hidden="true">·</span>
        <span>{subject}</span>
      </>
    )}
  </p>

  <div class="mb-8">
    <AudioPlayer audioBeats={audioBeats} />
  </div>

  <article class="prose">
    <slot />
  </article>

  {interactive && (
    <script
      type="application/json"
      data-page-interactive
      set:html={JSON.stringify(interactive)}
    />
  )}

  <zita-chat
    course="daily"
    lesson="0"
    piece-date={date}
    piece-id={pieceId}
    title={title}
  />
</BaseLayout>
