---
import BaseLayout from './BaseLayout.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
import '../styles/beats.css';
import '../styles/zita.css';

interface Props {
  title: string;
  courseTitle: string;
  courseSlug: string;
  lessonNumber: number;
  estimatedTime: string;
  audioSrc?: string;
}

const { title, courseTitle, courseSlug, lessonNumber, estimatedTime, audioSrc } = Astro.props;
const isDaily = courseSlug === 'daily';
const timeDisplay = estimatedTime?.includes('min') ? estimatedTime : `${estimatedTime} min`;
---

<BaseLayout title={`${title} — Zeemish`}>
  <nav class="text-sm text-zee-muted mb-6" aria-label="Breadcrumb">
    {isDaily ? (
      <>
        <a href="/daily/" class="hover:text-zee-primary transition-colors">Daily</a>
        <span class="mx-2">/</span>
        <span class="text-zee-text">{title}</span>
      </>
    ) : (
      <>
        <a href="/library/" class="hover:text-zee-primary transition-colors">Library</a>
        <span class="mx-2">/</span>
        <span class="text-zee-text">{courseTitle}</span>
        {lessonNumber > 0 && (
          <>
            <span class="mx-2">/</span>
            <span class="text-zee-text">Lesson {lessonNumber}</span>
          </>
        )}
      </>
    )}
  </nav>

  <h1 class="text-2xl md:text-3xl font-bold mb-2 leading-tight">{title}</h1>
  <p class="text-sm text-zee-muted mb-6">{timeDisplay}</p>

  <div class="mb-8">
    <AudioPlayer audioSrc={audioSrc} />
  </div>

  <article class="prose">
    <slot />
  </article>

  <zita-chat
    course={courseSlug}
    lesson={lessonNumber.toString()}
    title={title}
  />
</BaseLayout>
