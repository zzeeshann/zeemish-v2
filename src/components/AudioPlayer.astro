---
interface Props {
  audioBeats?: Record<string, string>;
}

const { audioBeats } = Astro.props;
const hasAudio = !!audioBeats && Object.keys(audioBeats).length > 0;
---

{hasAudio ? (
  <audio-player
    data-audio-beats={JSON.stringify(audioBeats)}
    class="block"
  >
    <div class="flex items-center gap-3 px-4 py-3 rounded-lg border border-zee-border bg-white/50">
      <button
        data-play-btn
        class="w-11 h-11 flex items-center justify-center rounded-full bg-zee-primary text-white hover:opacity-90 transition-opacity shrink-0"
        aria-label="Play audio"
        type="button"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M4 3L13 8L4 13V3Z" />
        </svg>
      </button>
      <div class="flex-1">
        <div
          data-progress
          class="h-1.5 bg-zee-border rounded-full overflow-hidden cursor-pointer"
          role="progressbar"
          aria-label="Audio progress"
        >
          <div data-progress-fill class="h-full w-0 bg-zee-primary rounded-full transition-[width] duration-75"></div>
        </div>
      </div>
      <span data-time class="text-sm text-zee-muted whitespace-nowrap tabular-nums">0:00</span>
    </div>
  </audio-player>
) : (
  <div class="flex items-center gap-3 px-4 py-3 rounded-lg border border-zee-border/50 bg-zee-bg">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-zee-muted shrink-0" aria-hidden="true">
      <path d="M9 18V5l12-2v13" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="6" cy="18" r="3"/>
      <circle cx="18" cy="16" r="3"/>
    </svg>
    <span class="text-sm text-zee-muted">Audio version coming soon</span>
  </div>
)}
